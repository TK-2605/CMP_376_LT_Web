@model RegisterViewModel

@{
    ViewData["Title"] = Localizer["Register"];
}

<section class="auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-7">
                <div class="auth-card auth-single-card">
                    <partial name="_AuthHomeButton" />
                    <div class="auth-form-side">
                        <div class="auth-form-heading text-center">
                            <h1>@Localizer["CreateAccount"]</h1>
                            <p>@Localizer["CreateAccountDesc"]</p>
                        </div>

                        <form asp-area="Identity" asp-controller="Account" asp-action="Register" method="post" class="auth-form">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                            <input asp-for="ReturnUrl" type="hidden" />

                            <div class="auth-field">
                                <label asp-for="FullName" class="form-label">@Localizer["FullName"]</label>
                                <input asp-for="FullName" class="form-control" autocomplete="name" placeholder="@Localizer["FullNamePlaceholder"]" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>

                            <div class="auth-field">
                                <label asp-for="StudentCode" class="form-label">@Localizer["StudentCode"]</label>
                                <input asp-for="StudentCode" class="form-control" placeholder="@Localizer["Optional"]" />
                                <span asp-validation-for="StudentCode" class="text-danger"></span>
                            </div>

                            <div class="auth-field">
                                <label asp-for="Email" class="form-label">@Localizer["Email"]</label>
                                <input asp-for="Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="auth-field">
                                        <label asp-for="Password" class="form-label">@Localizer["Password"]</label>
                                        <input asp-for="Password" class="form-control" autocomplete="new-password" placeholder="@Localizer["PasswordRequirement"]" />
                                        <span asp-validation-for="Password" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="auth-field">
                                        <label asp-for="ConfirmPassword" class="form-label">@Localizer["ConfirmPassword"]</label>
                                        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="@Localizer["ConfirmPasswordPlaceholder"]" />
                                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            @if (!Model.SmtpConfigured)
                            {
                                <div class="alert alert-warning mb-3" role="alert">
                                    Đăng ký đang tạm dừng vì dịch vụ email xác nhận chưa sẵn sàng.
                                    @if (!string.IsNullOrWhiteSpace(Model.EmailProviderProblem))
                                    {
                                        <span>@Model.EmailProviderProblem</span>
                                    }
                                </div>
                            }
                            <button type="submit" class="btn btn-primary auth-submit mt-2" disabled="@(!Model.SmtpConfigured)">@Localizer["CreateAccount"]</button>
                        </form>

                        @if (Model.ExternalLogins.Count > 0 || Model.ShowGoogleOAuthHint)
                        {
                            <div class="auth-divider"><span>@Localizer["Or"]</span></div>
                            <div class="auth-oauth-simple">
                                <p class="auth-oauth-label">Đăng ký bằng OAuth 2.0</p>

                                @foreach (var provider in Model.ExternalLogins)
                                {
                                    var providerName = provider.DisplayName ?? provider.Name;
                                    var isGoogle = string.Equals(provider.Name, "Google", StringComparison.OrdinalIgnoreCase);

                                    <form asp-area="Identity" asp-controller="Account" asp-action="ExternalLogin" method="post" class="mb-2">
                                        <input type="hidden" name="provider" value="@provider.Name" />
                                        <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                                        <button type="submit" class="btn auth-provider-button w-100 @(isGoogle ? "auth-google-button" : "btn-outline-secondary")">
                                            @if (isGoogle)
                                            {
                                                <span class="auth-google-mark">G</span>
                                            }
                                            else
                                            {
                                                <i class="ri-login-circle-line"></i>
                                            }
                                            <span>Tiếp tục với @providerName</span>
                                        </button>
                                    </form>
                                }

                                @if (Model.ShowGoogleOAuthHint)
                                {
                                    <button type="button" class="btn auth-provider-button auth-google-button is-disabled w-100" disabled>
                                        <span class="auth-google-mark">G</span>
                                        <span>Google OAuth 2.0 chưa cấu hình</span>
                                    </button>
                                    <p class="auth-oauth-hint">
                                        Cần thêm ClientId và ClientSecret để bật đăng ký Google thật.
                                    </p>
                                }
                            </div>
                        }

                        <p class="auth-switch">
                            @Localizer["AlreadyAccount"]
                            <a asp-area="Identity" asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Model.ReturnUrl">@Localizer["Login"]</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
