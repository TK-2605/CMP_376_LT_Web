@model RegisterViewModel

@{
    ViewData["Title"] = Localizer["Register"];
}

<section class="auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-7">
                <div class="auth-card auth-single-card">
                    <partial name="_AuthHomeButton" />
                    <div class="auth-form-side">
                        <div class="auth-form-heading text-center">
                            <h1>@Localizer["CreateAccount"]</h1>
                            <p>@Localizer["CreateAccountDesc"]</p>
                        </div>

                        <form asp-area="Identity" asp-controller="Account" asp-action="Register" method="post" class="auth-form">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                            <input asp-for="ReturnUrl" type="hidden" />

                            <div class="auth-field">
                                <label asp-for="FullName" class="form-label">@Localizer["FullName"]</label>
                                <input asp-for="FullName" class="form-control" autocomplete="name" placeholder="Nguyen Van A" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>

                            <div class="auth-field">
                                <label asp-for="StudentCode" class="form-label">@Localizer["StudentCode"]</label>
                                <input asp-for="StudentCode" class="form-control" placeholder="Neu co" />
                                <span asp-validation-for="StudentCode" class="text-danger"></span>
                            </div>

                            <div class="auth-field">
                                <label asp-for="Email" class="form-label">@Localizer["Email"]</label>
                                <input asp-for="Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="auth-field">
                                        <label asp-for="Password" class="form-label">@Localizer["Password"]</label>
                                        <input asp-for="Password" class="form-control" autocomplete="new-password" placeholder="Toi thieu 6 ky tu" />
                                        <span asp-validation-for="Password" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="auth-field">
                                        <label asp-for="ConfirmPassword" class="form-label">@Localizer["ConfirmPassword"]</label>
                                        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Nhap lai mat khau" />
                                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary auth-submit mt-2">@Localizer["CreateAccount"]</button>
                        </form>

                        <p class="auth-switch">
                            @Localizer["AlreadyAccount"]
                            <a asp-area="Identity" asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Model.ReturnUrl">@Localizer["Login"]</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
