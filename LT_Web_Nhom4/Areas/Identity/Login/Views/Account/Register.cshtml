@model RegisterViewModel

@{
    ViewData["Title"] = "Đăng ký";
}

<section class="auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-7">
                <div class="auth-card auth-single-card">
                    <partial name="_AuthHomeButton" />
                    <div class="auth-form-side">
                        <div class="auth-form-heading text-center">
                            <h1>Tạo tài khoản</h1>
                            <p>Điền thông tin cá nhân để tham gia lớp học và làm bài thi.</p>
                        </div>

                        <form asp-area="Identity" asp-controller="Account" asp-action="Register" method="post" class="auth-form">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                            <input asp-for="ReturnUrl" type="hidden" />

                            <div class="auth-field">
                                <label asp-for="FullName" class="form-label">Họ và tên</label>
                                <input asp-for="FullName" class="form-control" autocomplete="name" placeholder="Nguyễn Văn A" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>

                            <div class="auth-field">
                                <label asp-for="StudentCode" class="form-label">Mã sinh viên</label>
                                <input asp-for="StudentCode" class="form-control" placeholder="Nếu có" />
                                <span asp-validation-for="StudentCode" class="text-danger"></span>
                            </div>

                            <div class="auth-field">
                                <label asp-for="Email" class="form-label">Email</label>
                                <input asp-for="Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="auth-field">
                                        <label asp-for="Password" class="form-label">Mật khẩu</label>
                                        <input asp-for="Password" class="form-control" autocomplete="new-password" placeholder="Tối thiểu 6 ký tự" />
                                        <span asp-validation-for="Password" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="auth-field">
                                        <label asp-for="ConfirmPassword" class="form-label">Nhập lại mật khẩu</label>
                                        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Nhập lại mật khẩu" />
                                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary auth-submit mt-2">Tạo tài khoản</button>
                        </form>

                        <p class="auth-switch">
                            Đã có tài khoản?
                            <a asp-area="Identity" asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Model.ReturnUrl">Đăng nhập</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
