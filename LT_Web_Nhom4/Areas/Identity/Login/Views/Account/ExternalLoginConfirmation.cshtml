@model ExternalLoginConfirmationViewModel

@{
    ViewData["Title"] = "Xác nhận tài khoản";
}

<section class="auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="auth-card auth-single-card">
                    <partial name="_AuthHomeButton" />
                    <div class="auth-form-side">
                        <div class="auth-form-heading text-center">
                            <h1>Hoàn tất tài khoản</h1>
                            <p>Kiểm tra thông tin cá nhân trước khi vào hệ thống.</p>
                        </div>

                        <form asp-area="Identity" asp-controller="Account" asp-action="ExternalLoginConfirmation" method="post" class="auth-form">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                            <input asp-for="ReturnUrl" type="hidden" />

                            <div class="auth-field">
                                <label asp-for="FullName" class="form-label">Họ và tên</label>
                                <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn A" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>

                            <div class="auth-field">
                                <label asp-for="StudentCode" class="form-label">Mã sinh viên</label>
                                <input asp-for="StudentCode" class="form-control" placeholder="Nếu có" />
                                <span asp-validation-for="StudentCode" class="text-danger"></span>
                            </div>

                            <div class="auth-field">
                                <label asp-for="Email" class="form-label">Email</label>
                                <input asp-for="Email" class="form-control" readonly />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <button type="submit" class="btn btn-primary auth-submit">Hoàn tất</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
