@model ExternalLoginConfirmationViewModel

@{
    ViewData["Title"] = Localizer["ExternalAccountTitle"];
}

<section class="auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="auth-card auth-single-card">
                    <partial name="_AuthHomeButton" />
                    <div class="auth-form-side">
                        <div class="auth-form-heading text-center">
                            <span class="auth-kicker"><i class="ri-google-fill"></i> OAuth 2.0</span>
                            <h1>@Localizer["ExternalAccountTitle"]</h1>
                            <p>@Localizer["ExternalAccountDesc"]</p>
                        </div>

                        <form asp-area="Identity" asp-controller="Account" asp-action="ExternalLoginConfirmation" method="post" class="auth-form">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                            <input asp-for="ReturnUrl" type="hidden" />

                            <div class="auth-field">
                                <label asp-for="FullName" class="form-label">@Localizer["FullName"]</label>
                                <input asp-for="FullName" class="form-control" placeholder="@Localizer["FullNamePlaceholder"]" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>

                            <div class="auth-field">
                                <label asp-for="StudentCode" class="form-label">@Localizer["StudentCode"]</label>
                                <input asp-for="StudentCode" class="form-control" placeholder="@Localizer["Optional"]" />
                                <span asp-validation-for="StudentCode" class="text-danger"></span>
                            </div>

                            <div class="auth-field">
                                <label asp-for="Email" class="form-label">@Localizer["Email"]</label>
                                <input asp-for="Email" class="form-control" readonly />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <button type="submit" class="btn btn-primary auth-submit">@Localizer["Complete"]</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
