@{
    ViewData["Title"] = "Khong co quyen";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<section class="auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-7 col-lg-5">
                <div class="card auth-card">
                    <div class="card-body auth-form-side text-center">
                        <h1 class="h3 fw-bold">Ban khong co quyen truy cap</h1>
                        <p class="text-muted">Tai khoan hien tai khong co vai tro phu hop voi trang nay.</p>
                        <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-primary">Ve trang chu</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
