@model ResetPasswordOtpViewModel

@{
    ViewData["Title"] = Localizer["ResetPasswordTitle"];
}

<section class="auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="auth-card auth-single-card">
                    <partial name="_AuthHomeButton" />
                    <div class="auth-form-side">
                        <div class="auth-form-heading text-center">
                            <span class="auth-kicker"><i class="ri-lock-password-line"></i> OTP</span>
                            <h1>@Localizer["ResetPasswordTitle"]</h1>
                            <p>@Localizer["ResetPasswordOtpDesc"]</p>
                        </div>

                        @if (TempData["AuthMessage"] is string message)
                        {
                            var alertType = TempData["AuthMessageType"]?.ToString() == "danger" ? "danger" : "info";
                            <div class="alert alert-@alertType">@message</div>
                        }

                        <form asp-area="Identity" asp-controller="Account" asp-action="ResetPasswordOtp" method="post" class="auth-form">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                            <input asp-for="Email" type="hidden" />

                            <div class="auth-field">
                                <label asp-for="Code" class="form-label">@Localizer["OtpCode"]</label>
                                <input asp-for="Code" class="form-control auth-otp-input" inputmode="numeric" autocomplete="one-time-code" placeholder="000000" />
                                <span asp-validation-for="Code" class="text-danger"></span>
                            </div>

                            <div class="auth-field">
                                <label asp-for="NewPassword" class="form-label">@Localizer["NewPassword"]</label>
                                <input asp-for="NewPassword" class="form-control" autocomplete="new-password" placeholder="@Localizer["PasswordRequirement"]" />
                                <span asp-validation-for="NewPassword" class="text-danger"></span>
                            </div>

                            <div class="auth-field">
                                <label asp-for="ConfirmPassword" class="form-label">@Localizer["ConfirmNewPassword"]</label>
                                <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="@Localizer["ConfirmPasswordPlaceholder"]" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                            </div>

                            <button type="submit" class="btn btn-primary auth-submit">@Localizer["ChangePassword"]</button>
                        </form>

                        <form asp-area="Identity" asp-controller="Account" asp-action="ForgotPassword" method="post" class="mt-3">
                            <input type="hidden" name="Email" value="@Model.Email" />
                            <button type="submit" class="btn btn-outline-secondary w-100 auth-secondary-action">@Localizer["ResendOtp"]</button>
                        </form>
                        <a asp-area="Identity" asp-controller="Account" asp-action="Login" class="auth-back-link">@Localizer["BackToLogin"]</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
