@model ResetPasswordOtpViewModel

@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<section class="auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="auth-card auth-single-card">
                    <partial name="_AuthHomeButton" />
                    <div class="auth-form-side">
                        <div class="auth-form-heading text-center">
                            <h1>Đặt lại mật khẩu</h1>
                            <p>Nhập mã OTP trong email và mật khẩu mới.</p>
                        </div>

                        @if (TempData["AuthMessage"] is string message)
                        {
                            <div class="alert alert-info">@message</div>
                        }

                        <form asp-area="Identity" asp-controller="Account" asp-action="ResetPasswordOtp" method="post" class="auth-form">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                            <input asp-for="Email" type="hidden" />

                            <div class="auth-field">
                                <label asp-for="Code" class="form-label">Mã OTP</label>
                                <input asp-for="Code" class="form-control" inputmode="numeric" autocomplete="one-time-code" placeholder="000000" />
                                <span asp-validation-for="Code" class="text-danger"></span>
                            </div>

                            <div class="auth-field">
                                <label asp-for="NewPassword" class="form-label">Mật khẩu mới</label>
                                <input asp-for="NewPassword" class="form-control" autocomplete="new-password" placeholder="Tối thiểu 6 ký tự" />
                                <span asp-validation-for="NewPassword" class="text-danger"></span>
                            </div>

                            <div class="auth-field">
                                <label asp-for="ConfirmPassword" class="form-label">Nhập lại mật khẩu mới</label>
                                <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Nhập lại mật khẩu mới" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                            </div>

                            <button type="submit" class="btn btn-primary auth-submit">Đặt lại mật khẩu</button>
                        </form>

                        <a asp-area="Identity" asp-controller="Account" asp-action="Login" class="auth-back-link">Quay lại đăng nhập</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
