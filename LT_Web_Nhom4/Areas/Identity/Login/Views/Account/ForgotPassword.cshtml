@model ForgotPasswordViewModel

@{
    ViewData["Title"] = "Quen mat khau";
}

<section class="auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-7 col-lg-5">
                <div class="auth-card auth-single-card">
                    <partial name="_AuthHomeButton" />
                    <div class="auth-form-side">
                        <div class="auth-form-heading text-center">
                            <h1>Dat lai mat khau</h1>
                            <p>Nhap email tai khoan de nhan huong dan khoi phuc.</p>
                        </div>

                        <form asp-area="Identity" asp-controller="Account" asp-action="ForgotPassword" method="post" class="auth-form">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                            <div class="auth-field">
                                <label asp-for="Email" class="form-label">Email</label>
                                <input asp-for="Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                            <button type="submit" class="btn btn-primary auth-submit">Tiep tuc</button>
                        </form>

                        <a asp-area="Identity" asp-controller="Account" asp-action="Login" class="auth-back-link">Quay lại đăng nhập</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
