@model ForgotPasswordViewModel

@{
    ViewData["Title"] = Localizer["ForgotPasswordTitle"];
}

<section class="auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-7 col-lg-5">
                <div class="auth-card auth-single-card">
                    <partial name="_AuthHomeButton" />
                    <div class="auth-form-side">
                        <div class="auth-form-heading text-center">
                            <span class="auth-kicker"><i class="ri-mail-send-line"></i> Gmail SMTP</span>
                            <h1>@Localizer["ForgotPasswordTitle"]</h1>
                            <p>@Localizer["ForgotPasswordDesc"]</p>
                        </div>

                        @if (TempData["AuthMessage"] is string message)
                        {
                            <div class="alert alert-info">@message</div>
                        }

                        <form asp-area="Identity" asp-controller="Account" asp-action="ForgotPassword" method="post" class="auth-form">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                            <div class="auth-field">
                                <label asp-for="Email" class="form-label">@Localizer["Email"]</label>
                                <input asp-for="Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                            <button type="submit" class="btn btn-primary auth-submit">@Localizer["SendOtp"]</button>
                        </form>

                        <div class="auth-info-strip">
                            <span>01</span>
                            <p>@Localizer["ForgotPasswordHint"]</p>
                        </div>

                        <a asp-area="Identity" asp-controller="Account" asp-action="Login" class="auth-back-link">@Localizer["BackToLogin"]</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
