@model ConfirmRegistrationViewModel

@{
    ViewData["Title"] = Localizer["ConfirmRegistrationTitle"];
}

<section class="auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-7 col-lg-5">
                <div class="auth-card auth-single-card">
                    <partial name="_AuthHomeButton" />
                    <div class="auth-form-side">
                        <div class="auth-form-heading text-center">
                            <span class="auth-kicker"><i class="ri-shield-check-line"></i> OTP</span>
                            <h1>@Localizer["ConfirmRegistrationTitle"]</h1>
                            <p>@Localizer["ConfirmRegistrationDesc"]</p>
                        </div>

                        @if (TempData["AuthMessage"] is string message)
                        {
                            var alertType = TempData["AuthMessageType"]?.ToString() == "danger" ? "danger" : "info";
                            <div class="alert alert-@alertType">@message</div>
                        }

                        <form asp-area="Identity" asp-controller="Account" asp-action="ConfirmRegistration" method="post" class="auth-form">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                            <input asp-for="Email" type="hidden" />
                            <input asp-for="Token" type="hidden" />
                            <input asp-for="ReturnUrl" type="hidden" />

                            <div class="auth-field">
                                <label asp-for="Code" class="form-label">@Localizer["ConfirmCode"]</label>
                                <input asp-for="Code" class="form-control" inputmode="numeric" autocomplete="one-time-code" placeholder="000000" />
                                <span asp-validation-for="Code" class="text-danger"></span>
                            </div>

                            <button type="submit" class="btn btn-primary auth-submit">@Localizer["Confirm"]</button>
                        </form>

                        <form asp-area="Identity" asp-controller="Account" asp-action="ResendRegistrationCode" method="post" class="mt-3">
                            <input type="hidden" name="email" value="@Model.Email" />
                            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                            <button type="submit" class="btn btn-outline-secondary w-100 auth-secondary-action">@Localizer["ResendConfirmCode"]</button>
                        </form>

                        <a asp-area="Identity" asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Model.ReturnUrl" class="auth-back-link">@Localizer["BackToLogin"]</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
