@model LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<section class="auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-10">
                <div class="auth-card">
                    <partial name="_AuthHomeButton" />
                    <div class="row g-0">
                        <div class="col-lg-5 auth-panel">
                            <div class="auth-brand">
                                <span>QuizHub</span>
                            </div>
                            <div class="auth-panel-content">
                                <h1>Chào mừng trở lại</h1>
                                <p>Đăng nhập để vào lớp học, xem đề thi và tiếp tục bài làm của bạn.</p>
                            </div>
                            <div class="auth-panel-note">
                                <span>Lịch thi, bài làm và kết quả được quản lý tập trung.</span>
                            </div>
                        </div>
                        <div class="col-lg-7 auth-form-side">
                            <div class="auth-form-heading">
                                <h2>Đăng nhập</h2>
                                <p>Sử dụng email đã đăng ký với hệ thống.</p>
                            </div>

                            @if (TempData["AuthMessage"] is string message)
                            {
                                <div class="alert alert-info">@message</div>
                            }

                            <form asp-area="Identity" asp-controller="Account" asp-action="Login" method="post" class="auth-form">
                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                                <input asp-for="ReturnUrl" type="hidden" />

                                <div class="auth-field">
                                    <label asp-for="Email" class="form-label">Email</label>
                                    <input asp-for="Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>

                                <div class="auth-field">
                                    <label asp-for="Password" class="form-label">Mật khẩu</label>
                                    <input asp-for="Password" class="form-control" autocomplete="current-password" placeholder="Nhập mật khẩu" />
                                    <span asp-validation-for="Password" class="text-danger"></span>
                                </div>

                                <div class="auth-row">
                                    <div class="form-check">
                                        <input asp-for="RememberMe" class="form-check-input" />
                                        <label asp-for="RememberMe" class="form-check-label">Ghi nhớ tôi</label>
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-primary auth-submit">Đăng nhập</button>
                            </form>

                            @if (Model.ExternalLogins.Count > 0)
                            {
                                <div class="auth-divider"><span>hoặc</span></div>
                                @foreach (var provider in Model.ExternalLogins)
                                {
                                    <form asp-area="Identity" asp-controller="Account" asp-action="ExternalLogin" method="post" class="mb-2">
                                        <input type="hidden" name="provider" value="@provider.Name" />
                                        <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                                        <button type="submit" class="btn btn-outline-secondary auth-provider-button w-100">
                                            Đăng nhập bằng @provider.DisplayName
                                        </button>
                                    </form>
                                }
                            }

                            <p class="auth-switch">
                                Chưa có tài khoản?
                                <a asp-area="Identity" asp-controller="Account" asp-action="Register" asp-route-returnUrl="@Model.ReturnUrl">Đăng ký</a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
