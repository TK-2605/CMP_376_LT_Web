@model LoginViewModel

@{
    ViewData["Title"] = Localizer["Login"];
}

<section class="auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-10">
                <div class="auth-card">
                    <partial name="_AuthHomeButton" />
                    <div class="row g-0">
                        <div class="col-lg-5 auth-panel">
                            <div class="auth-brand">
                                <span>QuizHub</span>
                            </div>
                            <div class="auth-panel-content">
                                <h1>@Localizer["WelcomeBack"]</h1>
                                <p>@Localizer["LoginDesc"]</p>
                            </div>
                            <div class="auth-panel-note">
                                <span>@Localizer["LoginNote"]</span>
                            </div>
                        </div>
                        <div class="col-lg-7 auth-form-side">
                            <div class="auth-form-heading">
                                <h2>@Localizer["Login"]</h2>
                                <p>@Localizer["LoginDesc"]</p>
                            </div>

                            @if (TempData["AuthMessage"] is string message)
                            {
                                var alertType = TempData["AuthMessageType"]?.ToString() == "danger" ? "danger" : "info";
                                <div class="alert alert-@alertType">@message</div>
                            }

                            <form asp-area="Identity" asp-controller="Account" asp-action="Login" method="post" class="auth-form">
                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                                <input asp-for="ReturnUrl" type="hidden" />

                                <div class="auth-field">
                                    <label asp-for="Email" class="form-label">@Localizer["Email"]</label>
                                    <input asp-for="Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>

                                <div class="auth-field">
                                    <label asp-for="Password" class="form-label">@Localizer["Password"]</label>
                                    <input asp-for="Password" class="form-control" autocomplete="current-password" placeholder="@Localizer["PasswordPlaceholder"]" />
                                    <span asp-validation-for="Password" class="text-danger"></span>
                                </div>

                                <div class="auth-row">
                                    <div class="form-check">
                                        <input asp-for="RememberMe" class="form-check-input" />
                                        <label asp-for="RememberMe" class="form-check-label">@Localizer["RememberMe"]</label>
                                    </div>
                                    <a asp-area="Identity" asp-controller="Account" asp-action="ForgotPassword" class="auth-inline-link">@Localizer["ForgotPassword"]</a>
                                </div>

                                <button type="submit" class="btn btn-primary auth-submit">@Localizer["Login"]</button>
                            </form>

                            @if (Model.ExternalLogins.Count > 0 || Model.ShowGoogleOAuthHint)
                            {
                                <div class="auth-divider"><span>@Localizer["Or"]</span></div>
                                <div class="auth-oauth-simple">
                                    <p class="auth-oauth-label">Đăng nhập bằng OAuth 2.0</p>

                                    @foreach (var provider in Model.ExternalLogins)
                                    {
                                        var providerName = provider.DisplayName ?? provider.Name;
                                        var isGoogle = string.Equals(provider.Name, "Google", StringComparison.OrdinalIgnoreCase);

                                        <form asp-area="Identity" asp-controller="Account" asp-action="ExternalLogin" method="post" class="mb-2">
                                            <input type="hidden" name="provider" value="@provider.Name" />
                                            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                                            <button type="submit" class="btn auth-provider-button w-100 @(isGoogle ? "auth-google-button" : "btn-outline-secondary")">
                                                @if (isGoogle)
                                                {
                                                    <span class="auth-google-mark">G</span>
                                                }
                                                else
                                                {
                                                    <i class="ri-login-circle-line"></i>
                                                }
                                                <span>Tiếp tục với @providerName</span>
                                            </button>
                                        </form>
                                    }

                                    @if (Model.ShowGoogleOAuthHint)
                                    {
                                        <button type="button" class="btn auth-provider-button auth-google-button is-disabled w-100" disabled>
                                            <span class="auth-google-mark">G</span>
                                            <span>Google OAuth 2.0 chưa cấu hình</span>
                                        </button>
                                        <p class="auth-oauth-hint">
                                            Cần thêm ClientId và ClientSecret để bật đăng nhập Google thật.
                                        </p>
                                    }
                                </div>
                            }

                            <p class="auth-switch">
                                @Localizer["NoAccount"]
                                <a asp-area="Identity" asp-controller="Account" asp-action="Register" asp-route-returnUrl="@Model.ReturnUrl">@Localizer["Register"]</a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
