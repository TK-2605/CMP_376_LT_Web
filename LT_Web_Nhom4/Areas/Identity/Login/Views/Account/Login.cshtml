@model LoginViewModel

@{
    ViewData["Title"] = Localizer["Login"];
}

<section class="auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-10">
                <div class="auth-card">
                    <partial name="_AuthHomeButton" />
                    <div class="row g-0">
                        <div class="col-lg-5 auth-panel">
                            <div class="auth-brand">
                                <span>QuizHub</span>
                            </div>
                            <div class="auth-panel-content">
                                <h1>@Localizer["WelcomeBack"]</h1>
                                <p>@Localizer["LoginDesc"]</p>
                            </div>
                            <div class="auth-panel-note">
                                <span>Lich thi, bai lam va ket qua duoc quan ly tap trung.</span>
                            </div>
                        </div>
                        <div class="col-lg-7 auth-form-side">
                            <div class="auth-form-heading">
                                <h2>@Localizer["Login"]</h2>
                                <p>Su dung email da dang ky voi he thong.</p>
                            </div>

                            @if (TempData["AuthMessage"] is string message)
                            {
                                <div class="alert alert-info">@message</div>
                            }

                            <form asp-area="Identity" asp-controller="Account" asp-action="Login" method="post" class="auth-form">
                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                                <input asp-for="ReturnUrl" type="hidden" />

                                <div class="auth-field">
                                    <label asp-for="Email" class="form-label">@Localizer["Email"]</label>
                                    <input asp-for="Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>

                                <div class="auth-field">
                                    <label asp-for="Password" class="form-label">@Localizer["Password"]</label>
                                    <input asp-for="Password" class="form-control" autocomplete="current-password" placeholder="Nhap mat khau" />
                                    <span asp-validation-for="Password" class="text-danger"></span>
                                </div>

                                <div class="auth-row">
                                    <div class="form-check">
                                        <input asp-for="RememberMe" class="form-check-input" />
                                        <label asp-for="RememberMe" class="form-check-label">@Localizer["RememberMe"]</label>
                                    </div>
                                    <a asp-area="Identity" asp-controller="Account" asp-action="ForgotPassword">@Localizer["ForgotPassword"]</a>
                                </div>

                                <button type="submit" class="btn btn-primary auth-submit">@Localizer["Login"]</button>
                            </form>

                            @if (Model.ExternalLogins.Count > 0)
                            {
                                <div class="auth-divider"><span>hoac</span></div>
                                @foreach (var provider in Model.ExternalLogins)
                                {
                                    <form asp-area="Identity" asp-controller="Account" asp-action="ExternalLogin" method="post" class="mb-2">
                                        <input type="hidden" name="provider" value="@provider.Name" />
                                        <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                                        <button type="submit" class="btn btn-outline-secondary auth-provider-button w-100">
                                            Dang nhap bang @provider.DisplayName
                                        </button>
                                    </form>
                                }
                            }

                            <p class="auth-switch">
                                @Localizer["NoAccount"]
                                <a asp-area="Identity" asp-controller="Account" asp-action="Register" asp-route-returnUrl="@Model.ReturnUrl">@Localizer["Register"]</a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
