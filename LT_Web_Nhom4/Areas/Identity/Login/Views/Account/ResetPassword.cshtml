@model ResetPasswordViewModel

@{
    ViewData["Title"] = "Dat lai mat khau";
}

<section class="auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="auth-card auth-single-card">
                    <partial name="_AuthHomeButton" />
                    <div class="auth-form-side">
                        <div class="auth-form-heading text-center">
                            <h1>Dat lai mat khau</h1>
                            <p>Nhap mat khau moi cho tai khoan cua ban.</p>
                        </div>

                        <form asp-area="Identity" asp-controller="Account" asp-action="ResetPassword" method="post" class="auth-form">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                            <input asp-for="Email" type="hidden" />
                            <input asp-for="Token" type="hidden" />

                            <div class="auth-field">
                                <label asp-for="NewPassword" class="form-label">Mat khau moi</label>
                                <input asp-for="NewPassword" class="form-control" autocomplete="new-password" placeholder="Toi thieu 6 ky tu" />
                                <span asp-validation-for="NewPassword" class="text-danger"></span>
                            </div>

                            <div class="auth-field">
                                <label asp-for="ConfirmPassword" class="form-label">Nhap lai mat khau moi</label>
                                <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Nhap lai mat khau moi" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                            </div>

                            <button type="submit" class="btn btn-primary auth-submit">Dat lai mat khau</button>
                        </form>

                        <a asp-area="Identity" asp-controller="Account" asp-action="Login" class="auth-back-link">Quay lai dang nhap</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
