@model ResetPasswordViewModel

@{
    ViewData["Title"] = Localizer["ResetPasswordTitle"];
}

<section class="auth-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="auth-card auth-single-card">
                    <partial name="_AuthHomeButton" />
                    <div class="auth-form-side">
                        <div class="auth-form-heading text-center">
                            <span class="auth-kicker"><i class="ri-link"></i> Email link</span>
                            <h1>@Localizer["ResetPasswordTitle"]</h1>
                            <p>@Localizer["ResetPasswordLinkDesc"]</p>
                        </div>

                        <form asp-area="Identity" asp-controller="Account" asp-action="ResetPassword" method="post" class="auth-form">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                            <input asp-for="Email" type="hidden" />
                            <input asp-for="Token" type="hidden" />

                            <div class="auth-field">
                                <label asp-for="NewPassword" class="form-label">@Localizer["NewPassword"]</label>
                                <input asp-for="NewPassword" class="form-control" autocomplete="new-password" placeholder="@Localizer["PasswordRequirement"]" />
                                <span asp-validation-for="NewPassword" class="text-danger"></span>
                            </div>

                            <div class="auth-field">
                                <label asp-for="ConfirmPassword" class="form-label">@Localizer["ConfirmNewPassword"]</label>
                                <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="@Localizer["ConfirmNewPasswordPlaceholder"]" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                            </div>

                            <button type="submit" class="btn btn-primary auth-submit">@Localizer["ResetPassword"]</button>
                        </form>

                        <a asp-area="Identity" asp-controller="Account" asp-action="Login" class="auth-back-link">@Localizer["BackToLogin"]</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
