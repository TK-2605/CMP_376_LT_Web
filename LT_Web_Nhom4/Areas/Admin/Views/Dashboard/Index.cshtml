@model AdminDashboardViewModel

@{
    ViewData["Title"] = "Tổng quan";
}

<header class="admin-overview-header">
    <div>
        <span class="admin-crud-kicker">Hệ thống QuizHub</span>
        <h1>Tổng quan quản trị</h1>
        <p>Theo dõi tài khoản, lớp học, đề thi và tình hình làm bài.</p>
    </div>
    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="btn btn-primary">
        <i class="icon-base ri ri-refresh-line me-1"></i>Làm mới
    </a>
</header>

<div class="row gy-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card admin-stat-card">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div class="admin-stat-icon bg-label-primary"><i class="icon-base ri ri-user-3-line icon-24px text-primary"></i></div>
                    <span class="badge bg-label-success">@Model.ActiveUsers hoạt động</span>
                </div>
                <p class="mb-1">Tài khoản</p>
                <h4 class="card-title mb-0">@Model.TotalUsers</h4>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card admin-stat-card">
            <div class="card-body">
                <div class="admin-stat-icon bg-label-info mb-4"><i class="icon-base ri ri-book-2-line icon-24px text-info"></i></div>
                <p class="mb-1">Môn học</p>
                <h4 class="card-title mb-0">@Model.TotalSubjects</h4>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card admin-stat-card">
            <div class="card-body">
                <div class="admin-stat-icon bg-label-warning mb-4"><i class="icon-base ri ri-group-line icon-24px text-warning"></i></div>
                <p class="mb-1">Lớp học</p>
                <h4 class="card-title mb-0">@Model.TotalClasses</h4>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card admin-stat-card">
            <div class="card-body">
                <div class="admin-stat-icon bg-label-danger mb-4"><i class="icon-base ri ri-file-list-3-line icon-24px text-danger"></i></div>
                <p class="mb-1">Đề thi</p>
                <h4 class="card-title mb-0">@Model.TotalExams</h4>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header"><h5 class="mb-0">Chỉ số vận hành</h5></div>
            <div class="card-body">
                <ul class="admin-metric-list">
                    <li><span class="avatar-initial rounded bg-label-primary"><i class="icon-base ri ri-question-answer-line"></i></span><div><strong>Câu hỏi</strong><small>Ngân hàng câu hỏi</small></div><b>@Model.TotalQuestions</b></li>
                    <li><span class="avatar-initial rounded bg-label-success"><i class="icon-base ri ri-edit-box-line"></i></span><div><strong>Lượt thi</strong><small>Đang làm và đã nộp</small></div><b>@Model.TotalExamAttempts</b></li>
                    <li><span class="avatar-initial rounded bg-label-danger"><i class="icon-base ri ri-shield-check-line"></i></span><div><strong>Cảnh báo</strong><small>Sự kiện cần xem lại</small></div><b>@Model.TotalAntiCheatEvents</b></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card admin-table-card h-100">
            <div class="card-header d-flex align-items-center justify-content-between">
                <h5 class="mb-0">Đề thi gần đây</h5>
                <a href="/Admin/Exams" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
            </div>
            <div class="table-responsive">
                <table class="table">
                    <thead><tr><th>Đề thi</th><th>Lớp</th><th>Trạng thái</th><th>Câu hỏi</th><th>Lượt thi</th></tr></thead>
                    <tbody>
                        @if (Model.RecentExams.Count == 0)
                        {
                            <tr><td colspan="5" class="text-center text-muted">Chưa có đề thi</td></tr>
                        }
                        @foreach (var exam in Model.RecentExams)
                        {
                            <tr>
                                <td><strong>@exam.Title</strong><small class="d-block text-muted">@exam.SubjectName</small></td>
                                <td>@exam.ClassName</td>
                                <td><span class="badge bg-label-primary">@exam.Status.ToVietnamese()</span></td>
                                <td>@exam.QuestionCount</td>
                                <td>@exam.AttemptCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card admin-table-card">
            <div class="card-header d-flex align-items-center justify-content-between">
                <h5 class="mb-0">Tài khoản mới</h5>
                <a href="/Admin/Users" class="btn btn-sm btn-outline-primary">Quản lý tài khoản</a>
            </div>
            <div class="table-responsive">
                <table class="table">
                    <thead><tr><th>Tài khoản</th><th>Mã sinh viên</th><th>Trạng thái</th><th>Ngày tạo</th></tr></thead>
                    <tbody>
                        @if (Model.RecentUsers.Count == 0)
                        {
                            <tr><td colspan="4" class="text-center text-muted">Chưa có tài khoản</td></tr>
                        }
                        @foreach (var user in Model.RecentUsers)
                        {
                            var displayName = string.IsNullOrWhiteSpace(user.FullName) ? user.Email : user.FullName;
                            var initial = string.IsNullOrWhiteSpace(displayName) ? "?" : displayName.Trim()[0].ToString().ToUpperInvariant();
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <span class="avatar avatar-sm me-3"><span class="avatar-initial rounded-circle bg-label-primary">@initial</span></span>
                                        <div><strong>@displayName</strong><small class="d-block text-muted">@user.Email</small></div>
                                    </div>
                                </td>
                                <td>@(user.StudentCode ?? "—")</td>
                                <td><span class="badge @(user.IsActive ? "bg-label-success" : "bg-label-secondary")">@(user.IsActive ? "Đang hoạt động" : "Tạm khóa")</span></td>
                                <td>@user.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
