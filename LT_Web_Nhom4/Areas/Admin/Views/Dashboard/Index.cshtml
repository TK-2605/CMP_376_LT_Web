@model AdminDashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="row gy-4">
    <div class="col-12">
        <div class="card">
            <div class="d-flex align-items-end row">
                <div class="col-sm-7">
                    <div class="card-body admin-dashboard-heading">
                        <h4 class="card-title text-primary mb-2">Exam management overview</h4>
                        <p class="mb-4">
                            Track accounts, classes, exams, attempts and anti-cheat signals from one admin workspace.
                        </p>
                        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="btn btn-sm btn-primary">
                            <i class="icon-base ri ri-refresh-line me-1"></i>
                            Refresh
                        </a>
                    </div>
                </div>
                <div class="col-sm-5 text-center text-sm-left">
                    <div class="card-body pb-0 px-0 px-md-6">
                        <img src="~/img/illustrations/illustration-john-light.png" height="150" alt="Admin dashboard" data-app-light-img="illustrations/illustration-john-light.png" data-app-dark-img="illustrations/illustration-john-dark.png" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card admin-stat-card">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div class="admin-stat-icon bg-label-primary">
                        <i class="icon-base ri ri-user-3-line icon-24px text-primary"></i>
                    </div>
                    <span class="badge bg-label-success rounded-pill">@Model.ActiveUsers active</span>
                </div>
                <p class="mb-1">Users</p>
                <h4 class="card-title mb-0">@Model.TotalUsers</h4>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card admin-stat-card">
            <div class="card-body">
                <div class="admin-stat-icon bg-label-info mb-4">
                    <i class="icon-base ri ri-book-2-line icon-24px text-info"></i>
                </div>
                <p class="mb-1">Subjects</p>
                <h4 class="card-title mb-0">@Model.TotalSubjects</h4>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card admin-stat-card">
            <div class="card-body">
                <div class="admin-stat-icon bg-label-warning mb-4">
                    <i class="icon-base ri ri-group-line icon-24px text-warning"></i>
                </div>
                <p class="mb-1">Classes</p>
                <h4 class="card-title mb-0">@Model.TotalClasses</h4>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card admin-stat-card">
            <div class="card-body">
                <div class="admin-stat-icon bg-label-danger mb-4">
                    <i class="icon-base ri ri-file-list-3-line icon-24px text-danger"></i>
                </div>
                <p class="mb-1">Exams</p>
                <h4 class="card-title mb-0">@Model.TotalExams</h4>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0">System Counters</h5>
            </div>
            <div class="card-body">
                <ul class="p-0 m-0">
                    <li class="d-flex align-items-center mb-4">
                        <div class="avatar flex-shrink-0 me-3">
                            <span class="avatar-initial rounded bg-label-primary">
                                <i class="icon-base ri ri-question-answer-line"></i>
                            </span>
                        </div>
                        <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                            <div class="me-2">
                                <h6 class="mb-0">Questions</h6>
                                <small class="text-muted">Question bank</small>
                            </div>
                            <h6 class="mb-0">@Model.TotalQuestions</h6>
                        </div>
                    </li>
                    <li class="d-flex align-items-center mb-4">
                        <div class="avatar flex-shrink-0 me-3">
                            <span class="avatar-initial rounded bg-label-success">
                                <i class="icon-base ri ri-edit-box-line"></i>
                            </span>
                        </div>
                        <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                            <div class="me-2">
                                <h6 class="mb-0">Attempts</h6>
                                <small class="text-muted">Submitted and active</small>
                            </div>
                            <h6 class="mb-0">@Model.TotalExamAttempts</h6>
                        </div>
                    </li>
                    <li class="d-flex align-items-center">
                        <div class="avatar flex-shrink-0 me-3">
                            <span class="avatar-initial rounded bg-label-danger">
                                <i class="icon-base ri ri-shield-check-line"></i>
                            </span>
                        </div>
                        <div class="d-flex w-100 flex-wrap align-items-center justify-content-between gap-2">
                            <div class="me-2">
                                <h6 class="mb-0">Anti-cheat events</h6>
                                <small class="text-muted">Needs teacher review</small>
                            </div>
                            <h6 class="mb-0">@Model.TotalAntiCheatEvents</h6>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card admin-table-card h-100">
            <div class="card-header d-flex align-items-center justify-content-between">
                <h5 class="mb-0">Recent Exams</h5>
                <a href="/Admin/Exams" class="btn btn-sm btn-outline-primary">View all</a>
            </div>
            <div class="table-responsive text-nowrap">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Exam</th>
                            <th>Class</th>
                            <th>Status</th>
                            <th>Questions</th>
                            <th>Attempts</th>
                        </tr>
                    </thead>
                    <tbody class="table-border-bottom-0">
                        @if (Model.RecentExams.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">No exams yet</td>
                            </tr>
                        }
                        @foreach (var exam in Model.RecentExams)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="fw-medium">@exam.Title</span>
                                        <small class="text-muted">@exam.SubjectName</small>
                                    </div>
                                </td>
                                <td>@exam.ClassName</td>
                                <td><span class="badge bg-label-primary">@exam.Status</span></td>
                                <td>@exam.QuestionCount</td>
                                <td>@exam.AttemptCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card admin-table-card">
            <div class="card-header d-flex align-items-center justify-content-between">
                <h5 class="mb-0">Recent Users</h5>
                <a href="/Admin/Users" class="btn btn-sm btn-outline-primary">Manage users</a>
            </div>
            <div class="table-responsive text-nowrap">
                <table class="table">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Student Code</th>
                            <th>Status</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody class="table-border-bottom-0">
                        @if (Model.RecentUsers.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">No users yet</td>
                            </tr>
                        }
                        @foreach (var user in Model.RecentUsers)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar avatar-sm me-3">
                                            <span class="avatar-initial rounded-circle bg-label-primary">
                                                @((string.IsNullOrWhiteSpace(user.FullName) ? user.Email : user.FullName).Substring(0, 1).ToUpperInvariant())
                                            </span>
                                        </div>
                                        <div>
                                            <span class="fw-medium">@user.FullName</span>
                                            <small class="d-block text-muted">@user.Email</small>
                                        </div>
                                    </div>
                                </td>
                                <td>@(user.StudentCode ?? "-")</td>
                                <td>
                                    <span class="badge @(user.IsActive ? "bg-label-success" : "bg-label-secondary")">
                                        @(user.IsActive ? "Active" : "Locked")
                                    </span>
                                </td>
                                <td>@user.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
