@model CrudIndexViewModel

@{
    ViewData["Title"] = Model.Title;
    var visibleFields = Model.Fields.Where(field => field.ShowInList).ToList();
}

<section class="admin-crud-page">
    <div class="admin-crud-header">
        <div>
            <span class="admin-crud-kicker">Danh mục quản trị</span>
            <h1>@Model.Title</h1>
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p>@Model.Description</p>
            }
        </div>
        <a asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="Create" class="btn btn-primary">
            <i class="icon-base ri ri-add-line me-1"></i>
            Thêm mới
        </a>
    </div>

    <div class="admin-crud-toolbar">
        <div class="admin-crud-search">
            <i class="icon-base ri ri-search-line"></i>
            <input type="search" class="form-control" placeholder="Tìm trong @Model.Title.ToLowerInvariant()" data-admin-table-filter />
        </div>
        <div class="admin-crud-count">
            <strong>@Model.Rows.Count</strong>
            <span>bản ghi</span>
        </div>
    </div>

    <div class="card admin-crud-card">
        @if (TempData["AdminMessage"] is string message)
        {
            <div class="alert alert-success admin-crud-alert mb-0" role="alert">
                <i class="icon-base ri ri-check-line me-1"></i>
                @message
            </div>
        }
        <div class="table-responsive">
            <table class="table admin-crud-table align-middle mb-0">
                <thead>
                    <tr>
                        @foreach (var field in visibleFields)
                        {
                            <th>@field.Label</th>
                        }
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody data-admin-table-body>
                    @if (Model.Rows.Count == 0)
                    {
                        <tr>
                            <td colspan="@(visibleFields.Count + 1)">
                                <div class="admin-crud-empty">
                                    <i class="icon-base ri ri-inbox-line"></i>
                                    <strong>Chưa có dữ liệu</strong>
                                    <span>Hãy thêm bản ghi đầu tiên cho danh mục này.</span>
                                </div>
                            </td>
                        </tr>
                    }
                    @foreach (var row in Model.Rows)
                    {
                        <tr data-admin-table-row>
                            @foreach (var field in visibleFields)
                            {
                                <td>
                                    <span class="admin-crud-cell">@(row.Values.TryGetValue(field.Name, out var value) ? value : "-")</span>
                                </td>
                            }
                            <td class="text-end text-nowrap">
                                @if (string.Equals(Model.ControllerName, "Users", StringComparison.OrdinalIgnoreCase))
                                {
                                    var isActive = row.Values.TryGetValue("IsActive", out var activeText) && string.Equals(activeText, "Đang hoạt động", StringComparison.OrdinalIgnoreCase);
                                    <div class="admin-row-actions">
                                        <a asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="Details" asp-route-id="@row.Key" class="btn btn-sm btn-outline-secondary"><i class="icon-base ri ri-eye-line"></i> Xem</a>
                                        <a asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="Edit" asp-route-id="@row.Key" class="btn btn-sm btn-outline-primary"><i class="icon-base ri ri-edit-2-line"></i> Sửa</a>
                                        <a asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="ManageRoles" asp-route-id="@row.Key" class="btn btn-sm btn-outline-info"><i class="icon-base ri ri-shield-user-line"></i> Phân quyền</a>
                                        <form asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="ToggleActive" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@row.Key" />
                                            <button type="submit" class="btn btn-sm @(isActive ? "btn-outline-warning" : "btn-outline-success")" data-confirm="@(isActive ? "Khóa tài khoản này?" : "Mở khóa tài khoản này?")">
                                                <i class="icon-base ri @(isActive ? "ri-lock-line" : "ri-lock-unlock-line")"></i> @(isActive ? "Khóa" : "Mở")
                                            </button>
                                        </form>
                                        <a asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="Delete" asp-route-id="@row.Key" class="btn btn-sm btn-outline-danger"><i class="icon-base ri ri-delete-bin-6-line"></i> Xóa</a>
                                    </div>
                                }
                                else
                                {
                                    <a asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="Details" asp-route-id="@row.Key" class="btn btn-sm btn-outline-secondary" title="Xem chi tiết">
                                        <i class="icon-base ri ri-eye-line"></i>
                                    </a>
                                    <a asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="Edit" asp-route-id="@row.Key" class="btn btn-sm btn-outline-primary" title="Sửa">
                                        <i class="icon-base ri ri-edit-2-line"></i>
                                    </a>
                                    <a asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="Delete" asp-route-id="@row.Key" class="btn btn-sm btn-outline-danger" title="Xoá">
                                        <i class="icon-base ri ri-delete-bin-6-line"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
