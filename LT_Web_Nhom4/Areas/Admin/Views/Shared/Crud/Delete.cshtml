@model CrudDeleteViewModel

@{
    ViewData["Title"] = $"Xoá {Model.Title}";
    var visibleFields = Model.Fields.Where(field => field.ShowInDetails).Take(6).ToList();
}

<section class="admin-crud-page">
    <div class="admin-form-shell">
        <div class="admin-crud-header">
            <div>
                <span class="admin-crud-kicker text-danger">Xác nhận xóa</span>
                <h1>Xoá @Model.Title</h1>
                <p>Bản ghi sẽ bị xóa khỏi khu vực quản trị sau khi xác nhận.</p>
            </div>
        </div>

        <div class="card admin-crud-card admin-form-card border-danger">
            <div class="card-body">
                <dl class="admin-detail-list">
                    @foreach (var field in visibleFields)
                    {
                        <div>
                            <dt>@field.Label</dt>
                            <dd>@(field.IsBoolean ? (field.Value == "true" ? "Có" : "Không") : field.Value ?? "-")</dd>
                        </div>
                    }
                </dl>

                <form asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="Delete" asp-route-id="@Model.Key" method="post">
                    <div class="admin-form-actions">
                        <a asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="Index" class="btn btn-outline-secondary">
                            <i class="icon-base ri ri-arrow-left-line me-1"></i>
                            Huỷ
                        </a>
                        <button type="submit" class="btn btn-danger">
                            <i class="icon-base ri ri-delete-bin-6-line me-1"></i>
                            Xoá
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
