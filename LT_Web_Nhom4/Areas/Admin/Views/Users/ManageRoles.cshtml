@model AdminRoleAssignmentViewModel

@{
    ViewData["Title"] = "Phân quyền tài khoản";

    string RoleDescription(string role)
    {
        return role switch
        {
            "Admin" => "Toàn quyền quản trị hệ thống, tài khoản, dữ liệu và cấu hình.",
            "Student" => "Vào lớp học, xem đề thi và thực hiện bài làm.",
            _ => "Nhóm quyền tùy chỉnh trong hệ thống."
        };
    }
}

<section class="admin-crud-page">
    <div class="admin-form-shell">
        <div class="admin-crud-header">
            <div>
                <span class="admin-crud-kicker">Phân quyền truy cập</span>
                <h1>Cấp quyền tài khoản</h1>
                <p>Chọn nhóm quyền đúng với vai trò thực tế của người dùng trong hệ thống.</p>
            </div>
        </div>

        <div class="card admin-crud-card admin-form-card">
            <div class="card-body">
                <div class="admin-role-summary">
                    <div>
                        <strong>@(string.IsNullOrWhiteSpace(Model.FullName) ? Model.Email : Model.FullName)</strong>
                        <span>@Model.Email</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.StudentCode))
                    {
                        <span class="badge bg-label-primary">@Model.StudentCode</span>
                    }
                </div>

                <form asp-area="Admin" asp-controller="Users" asp-action="ManageRoles" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mt-3"></div>
                    <input asp-for="UserId" type="hidden" />
                    <input asp-for="Email" type="hidden" />
                    <input asp-for="FullName" type="hidden" />
                    <input asp-for="StudentCode" type="hidden" />

                    @if (Model.AvailableRoles.Count == 0)
                    {
                        <div class="admin-crud-empty">
                            <i class="icon-base ri ri-shield-user-line"></i>
                            <strong>Chưa có vai trò</strong>
                            <span>Tạo vai trò trước, sau đó quay lại cấp quyền cho tài khoản.</span>
                        </div>
                    }
                    else
                    {
                        <div class="admin-role-options">
                            @foreach (var role in Model.AvailableRoles)
                            {
                                var checkboxId = $"role_{role}";
                                <label class="admin-role-option" for="@checkboxId">
                                    <input id="@checkboxId"
                                           class="form-check-input"
                                           type="checkbox"
                                           name="SelectedRoles"
                                           value="@role"
                                           checked="@Model.SelectedRoles.Contains(role, StringComparer.OrdinalIgnoreCase)" />
                                    <span>
                                        <strong>@role</strong>
                                        <span>@RoleDescription(role)</span>
                                    </span>
                                </label>
                            }
                        </div>
                    }

                    <div class="admin-form-actions">
                        <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="btn btn-outline-secondary">
                            <i class="icon-base ri ri-arrow-left-line me-1"></i>
                            Huỷ
                        </a>
                        <a asp-area="Admin" asp-controller="Roles" asp-action="Index" class="btn btn-outline-primary">
                            <i class="icon-base ri ri-lock-2-line me-1"></i>
                            Quản lý vai trò
                        </a>
                        <button type="submit" class="btn btn-primary" disabled="@(Model.AvailableRoles.Count == 0)">
                            <i class="icon-base ri ri-save-3-line me-1"></i>
                            Lưu phân quyền
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
