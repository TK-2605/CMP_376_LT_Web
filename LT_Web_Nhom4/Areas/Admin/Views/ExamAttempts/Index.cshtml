@model IReadOnlyList<AdminExamAttemptViewModel>

@{
    ViewData["Title"] = "Luot thi";
}

<section class="admin-crud-page">
    <div class="admin-crud-header">
        <div>
            <span class="admin-crud-kicker">Theo doi bai thi</span>
            <h1>Luot thi cua sinh vien</h1>
            <p>So lan vi pham lon hon 3 se duoc danh dau nghi ngo gian lan.</p>
        </div>
    </div>

    <div class="card admin-crud-card">
        <div class="table-responsive">
            <table class="table admin-crud-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>De thi</th>
                        <th>Sinh vien</th>
                        <th>Bat dau</th>
                        <th>Trang thai</th>
                        <th>So lan vi pham</th>
                        <th>Danh gia</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr><td colspan="6" class="text-center py-5 text-muted">Chua co luot thi nao.</td></tr>
                    }
                    @foreach (var attempt in Model)
                    {
                        var suspicious = attempt.AntiCheatEventCount > 3;
                        <tr>
                            <td>@attempt.ExamTitle</td>
                            <td>
                                <strong class="d-block">@attempt.StudentName</strong>
                                <small class="text-muted">@attempt.StudentEmail</small>
                            </td>
                            <td>@attempt.StartedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@attempt.Status</td>
                            <td><span class="badge bg-label-@(suspicious ? "danger" : "info")">@attempt.AntiCheatEventCount</span></td>
                            <td>
                                <span class="badge bg-label-@(suspicious ? "danger" : "success")">
                                    @(suspicious ? "Nghi ngo gian lan" : "Binh thuong")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
