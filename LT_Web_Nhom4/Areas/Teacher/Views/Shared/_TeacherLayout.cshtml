@{
    var title = ViewData["Title"] as string ?? "Giao vien";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - Giao vien</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/teacher.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="teacher-body">
    <div class="teacher-shell">
        <aside class="teacher-sidebar">
            <a asp-area="Teacher" asp-controller="Dashboard" asp-action="Index" class="teacher-brand">QuizHub Teacher</a>
            <nav class="teacher-menu">
                <a asp-area="Teacher" asp-controller="Dashboard" asp-action="Index">Tong quan</a>
                <a asp-area="" asp-controller="Classes" asp-action="Index">Lop hoc</a>
                <a asp-area="" asp-controller="Questions" asp-action="Index">Cau hoi</a>
                <a asp-area="" asp-controller="QuestionOptions" asp-action="Index">Dap an</a>
                <a asp-area="" asp-controller="ExamQuestions" asp-action="Index">Cau hoi trong de</a>
                <a asp-area="" asp-controller="AntiCheat" asp-action="Index">Canh bao</a>
            </nav>
        </aside>

        <div class="teacher-main">
            <header class="teacher-topbar">
                <div>
                    <span>Khu vuc giao vien</span>
                    <strong>@title</strong>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-secondary">Trang chu</a>
                    <form asp-area="Identity"
                          asp-controller="Account"
                          asp-action="Logout"
                          asp-route-returnUrl="@Url.Action("Login", "Account", new { area = "Identity" })"
                          method="post">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Dang xuat</button>
                    </form>
                </div>
            </header>

            <main class="teacher-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
