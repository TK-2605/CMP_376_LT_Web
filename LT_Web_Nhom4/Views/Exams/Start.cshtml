@model ExamStartViewModel

@{
    ViewData["Title"] = Model.Title;
    ViewData["BodyClass"] = "exam-body";
}

@section Styles {
    <link rel="stylesheet" href="~/css/exam.css" asp-append-version="true" />
}

<div class="exam-shell">
    <div class="container">
        <div class="exam-header mb-4">
            <div class="row align-items-center g-4">
                <div class="col-lg-8">
                    <span class="badge text-bg-light text-primary mb-3">@Model.SubjectName</span>
                    <h1 class="h2 fw-bold mb-2">@Model.Title</h1>
                    <p class="mb-0 text-white-50">@Localizer["ExamInstructions"]</p>
                </div>
                <div class="col-lg-4">
                    <div class="card exam-timer-card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="fw-semibold text-dark">@Localizer["TimeRemaining"]</span>
                                <span class="h4 mb-0 text-primary" data-exam-timer-label>--:--</span>
                            </div>
                            <div class="exam-timer-bar">
                                <span data-exam-timer-bar></span>
                            </div>
                            <div class="exam-autosave small mt-3" data-exam-autosave></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <form asp-controller="Exams"
              asp-action="Submit"
              method="post"
              data-exam-form
              data-duration-minutes="@Model.DurationMinutes"
              data-started-at="@Model.StartedAt.ToUniversalTime().ToString("O")"
              data-autosave-url="@Url.Action("Autosave", "Exams")"
              data-anti-cheat-url="@Url.Action("Report", "ExamSecurity")"
              data-anti-cheat-warning="@Localizer["AntiCheatWarning"]"
              data-anti-cheat-suspicious="@Localizer["AntiCheatSuspicious"]"
              data-saved-at="@Localizer["SavedAt"]"
              data-autosave-failed="@Localizer["AutosaveFailed"]"
              data-connection-unstable="@Localizer["ConnectionUnstable"]"
              data-unanswered-confirm="@Localizer["UnansweredConfirm"]"
              data-submitting="@Localizer["Submitting"]">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <input type="hidden" name="ExamId" value="@Model.ExamId" />
            <input type="hidden" name="AttemptId" value="@Model.AttemptId" />

            <div class="row g-4">
                <div class="col-lg-8">
                    @for (var i = 0; i < Model.Questions.Count; i++)
                    {
                        var question = Model.Questions[i];
                        <section class="card exam-question-card mb-4" data-question-id="@question.QuestionId">
                            <div class="card-body p-4">
                                <input type="hidden" name="Answers[@i].QuestionId" value="@question.QuestionId" />
                                <div class="d-flex justify-content-between gap-3 mb-3">
                                    <h2 class="h5 fw-bold mb-0">@Localizer["Question", i + 1]. @question.Content</h2>
                                    <span class="badge text-bg-light">@Localizer["Points", question.Score]</span>
                                </div>

                                <div class="d-grid gap-3">
                                    @foreach (var option in question.Options)
                                    {
                                        var inputId = $"q_{question.QuestionId}_o_{option.OptionId}";
                                        <label class="exam-option" for="@inputId">
                                            <input id="@inputId"
                                                   class="form-check-input me-2"
                                                   type="radio"
                                                   name="Answers[@i].SelectedOptionId"
                                                   value="@option.OptionId" />
                                            <span>@option.Content</span>
                                        </label>
                                    }
                                </div>
                                <span class="text-danger field-validation-valid" data-valmsg-for="Answers[@i].SelectedOptionId" data-valmsg-replace="true"></span>
                            </div>
                        </section>
                    }
                </div>

                <div class="col-lg-4">
                    <div class="card exam-navigation-card sticky-top" style="top: 96px;">
                        <div class="card-body p-4">
                            <h2 class="h5 fw-bold">@Localizer["Progress"]</h2>
                            <p class="text-muted small">@Localizer["ProgressHint"]</p>
                            <div class="d-flex flex-wrap gap-2 mb-4">
                                @foreach (var question in Model.Questions)
                                {
                                    <span class="exam-progress-dot" data-progress-question="@question.QuestionId"></span>
                                }
                            </div>

                            <div class="alert alert-warning small">
                                @Localizer["ExamSafetyWarning"]
                            </div>

                            <div class="alert alert-info small d-none" role="status" data-anti-cheat-status></div>

                            <button type="submit" class="btn btn-primary w-100">@Localizer["SubmitExam"]</button>
                            <a asp-controller="Exams" asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">@Localizer["Exit"]</a>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/exam.js" asp-append-version="true"></script>
}
