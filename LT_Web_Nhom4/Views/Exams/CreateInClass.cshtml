@model CreateExamInClassViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Tao de thi";
    var statusOptions = new List<SelectListItem>
    {
        new("Bản nháp", ExamStatus.Draft.ToString()),
        new("Mở cho học viên", ExamStatus.Published.ToString()),
        new("Đã đóng", ExamStatus.Closed.ToString()),
        new("Đã huỷ", ExamStatus.Cancelled.ToString())
    };
    var typeOptions = new List<SelectListItem>
    {
        new("Trắc nghiệm 1 đáp án", QuestionType.SingleChoice.ToString()),
        new("Trắc nghiệm nhiều đáp án", QuestionType.MultipleChoice.ToString())
    };
    var difficultyOptions = new List<SelectListItem>
    {
        new("Dễ", QuestionDifficulty.Easy.ToString()),
        new("Trung bình", QuestionDifficulty.Medium.ToString()),
        new("Khó", QuestionDifficulty.Hard.ToString())
    };
}

<section class="exam-builder-page">
    <div class="container">
        <form asp-controller="Exams" asp-action="CreateInClass" method="post" id="examBuilderForm">
            <input asp-for="ClassId" type="hidden" />
            <input asp-for="ClassCode" type="hidden" />
            <input asp-for="ClassName" type="hidden" />

            <div class="exam-builder-topbar">
                <a asp-controller="Classes" asp-action="Details" asp-route-id="@Model.ClassId" class="btn btn-light">
                    &larr; Về lớp
                </a>
                <div class="exam-builder-actions">
                    <button type="submit" class="btn btn-outline-primary">Lưu nháp</button>
                    <button type="submit" class="btn btn-primary">Lưu đề thi</button>
                </div>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="exam-builder-grid">
                <main class="exam-builder-main">
                    <section class="exam-builder-hero">
                        <div class="exam-builder-kicker">Đề thi trong lớp</div>
                        <h1>Tạo đề thi</h1>
                        <p>Soạn đề, thêm câu hỏi và đáp án trên cùng một màn hình. Hệ thống tự gắn lớp, môn học và người tạo.</p>
                        <div class="exam-readonly-class">
                            <span>Lớp hiện tại</span>
                            <strong>@Model.ClassCode - @Model.ClassName</strong>
                        </div>
                    </section>

                    <section class="exam-builder-card">
                        <div class="exam-builder-card-header">
                            <div>
                                <span>Thông tin đề</span>
                                <h2>Cấu hình bài thi</h2>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-lg-8">
                                <label asp-for="Title" class="form-label">Tên đề thi</label>
                                <input asp-for="Title" class="form-control form-control-lg" placeholder="Ví dụ: Kiểm tra chương 1" />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>
                            <div class="col-lg-4">
                                <label asp-for="DurationMinutes" class="form-label">Thời lượng phút</label>
                                <input asp-for="DurationMinutes" class="form-control form-control-lg" />
                                <span asp-validation-for="DurationMinutes" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="StartAt" class="form-label">Bắt đầu</label>
                                <input asp-for="StartAt" class="form-control" type="datetime-local" />
                                <span asp-validation-for="StartAt" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EndAt" class="form-label">Kết thúc</label>
                                <input asp-for="EndAt" class="form-control" type="datetime-local" />
                                <span asp-validation-for="EndAt" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="MaxScore" class="form-label">Điểm tối đa</label>
                                <input asp-for="MaxScore" class="form-control" />
                                <span asp-validation-for="MaxScore" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="PassingScore" class="form-label">Điểm đạt</label>
                                <input asp-for="PassingScore" class="form-control" placeholder="Ví dụ: 5" />
                                <span asp-validation-for="PassingScore" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Status" class="form-label">Trạng thái</label>
                                <select asp-for="Status" asp-items="statusOptions" class="form-select"></select>
                                <span asp-validation-for="Status" class="text-danger"></span>
                            </div>
                        </div>
                    </section>

                    <div id="questionList" class="exam-question-builder-list">
                        @for (var questionIndex = 0; questionIndex < Model.Questions.Count; questionIndex++)
                        {
                            var question = Model.Questions[questionIndex];
                            <section class="exam-question-builder-card" data-question-card>
                                <div class="exam-question-toolbar">
                                    <span class="question-number">Câu hỏi @(questionIndex + 1)</span>
                                    <div>
                                        <button type="button" class="btn btn-light btn-sm" data-duplicate-question>Nhân bản</button>
                                        <button type="button" class="btn btn-outline-danger btn-sm" data-remove-question>Xoá</button>
                                    </div>
                                </div>

                                <div class="row g-3">
                                    <div class="col-lg-8">
                                        <label class="form-label" for="Questions_@(questionIndex)__Content">Nội dung câu hỏi</label>
                                        <textarea id="Questions_@(questionIndex)__Content" name="Questions[@questionIndex].Content" class="form-control question-content" rows="3" placeholder="Nhập câu hỏi...">@question.Content</textarea>
                                        <span class="text-danger field-validation-valid" data-valmsg-for="Questions[@questionIndex].Content" data-valmsg-replace="true"></span>
                                    </div>
                                    <div class="col-lg-4">
                                        <label class="form-label" for="Questions_@(questionIndex)__QuestionType">Loại câu hỏi</label>
                                        <select id="Questions_@(questionIndex)__QuestionType" name="Questions[@questionIndex].QuestionType" class="form-select" data-question-type>
                                            @foreach (var item in typeOptions)
                                            {
                                                <option value="@item.Value" selected="@(item.Value == question.QuestionType.ToString())">@item.Text</option>
                                            }
                                        </select>

                                        <div class="row g-2 mt-2">
                                            <div class="col-6">
                                                <label class="form-label" for="Questions_@(questionIndex)__Score">Điểm</label>
                                                <input id="Questions_@(questionIndex)__Score" name="Questions[@questionIndex].Score" value="@question.Score" class="form-control" placeholder="Tự chia" />
                                                <span class="text-danger field-validation-valid" data-valmsg-for="Questions[@questionIndex].Score" data-valmsg-replace="true"></span>
                                            </div>
                                            <div class="col-6">
                                                <label class="form-label" for="Questions_@(questionIndex)__Difficulty">Độ khó</label>
                                                <select id="Questions_@(questionIndex)__Difficulty" name="Questions[@questionIndex].Difficulty" class="form-select">
                                                    @foreach (var item in difficultyOptions)
                                                    {
                                                        <option value="@item.Value" selected="@(item.Value == question.Difficulty.ToString())">@item.Text</option>
                                                    }
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label" for="Questions_@(questionIndex)__ImageUrl">Ảnh câu hỏi</label>
                                        <input id="Questions_@(questionIndex)__ImageUrl" name="Questions[@questionIndex].ImageUrl" value="@question.ImageUrl" class="form-control" placeholder="Dán link ảnh nếu có" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label" for="Questions_@(questionIndex)__VideoUrl">Video câu hỏi</label>
                                        <input id="Questions_@(questionIndex)__VideoUrl" name="Questions[@questionIndex].VideoUrl" value="@question.VideoUrl" class="form-control" placeholder="Dán link video nếu có" />
                                    </div>
                                </div>

                                <div class="answer-builder-list" data-answer-list>
                                    @for (var optionIndex = 0; optionIndex < question.Options.Count; optionIndex++)
                                    {
                                        var option = question.Options[optionIndex];
                                        <div class="answer-builder-row" data-answer-row>
                                            <input type="hidden" name="Questions[@questionIndex].Options[@optionIndex].IsCorrect" value="false" />
                                            <input class="form-check-input" type="checkbox" name="Questions[@questionIndex].Options[@optionIndex].IsCorrect" value="true" checked="@option.IsCorrect" title="Đáp án đúng" />
                                            <input name="Questions[@questionIndex].Options[@optionIndex].Content" value="@option.Content" class="form-control" placeholder="Nhập đáp án" />
                                            <button type="button" class="btn btn-light btn-sm" data-remove-answer>Xoá</button>
                                        </div>
                                    }
                                </div>

                                <div class="d-flex flex-wrap justify-content-between gap-2 mt-3">
                                    <button type="button" class="btn btn-outline-primary btn-sm" data-add-answer>+ Thêm đáp án</button>
                                    <textarea name="Questions[@questionIndex].Explanation" class="form-control question-explanation" rows="2" placeholder="Giải thích đáp án sau khi nộp bài nếu cần">@question.Explanation</textarea>
                                </div>
                            </section>
                        }
                    </div>

                    <section class="exam-add-question-panel">
                        <button type="button" class="btn btn-primary" id="addQuestionButton">+ Thêm câu hỏi</button>
                        <button type="button" class="btn btn-outline-primary" id="addSampleQuestionButton">+ Thêm câu hỏi mẫu</button>
                    </section>
                </main>

                <aside class="exam-builder-side">
                    <div class="exam-builder-side-card">
                        <h2>Cài đặt thi</h2>
                        <label class="exam-toggle-item">
                            <input asp-for="ShuffleQuestions" />
                            <span>Trộn câu hỏi</span>
                        </label>
                        <label class="exam-toggle-item">
                            <input asp-for="ShuffleOptions" />
                            <span>Trộn đáp án</span>
                        </label>
                        <label class="exam-toggle-item">
                            <input asp-for="RequireFullscreen" />
                            <span>Yêu cầu toàn màn hình</span>
                        </label>
                        <label asp-for="MaxTabSwitchCount" class="form-label mt-3">Số lần rời màn hình tối đa</label>
                        <input asp-for="MaxTabSwitchCount" class="form-control" />
                    </div>

                    <div class="exam-builder-side-card">
                        <h2>Chấm điểm</h2>
                        <p>Nếu để trống điểm từng câu, hệ thống sẽ chia đều phần điểm còn lại theo điểm tối đa của bài.</p>
                    </div>
                </aside>
            </div>
        </form>
    </div>
</section>

<template id="questionTemplate">
    <section class="exam-question-builder-card" data-question-card>
        <div class="exam-question-toolbar">
            <span class="question-number">Câu hỏi __NUMBER__</span>
            <div>
                <button type="button" class="btn btn-light btn-sm" data-duplicate-question>Nhân bản</button>
                <button type="button" class="btn btn-outline-danger btn-sm" data-remove-question>Xoá</button>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-lg-8">
                <label class="form-label">Nội dung câu hỏi</label>
                <textarea name="Questions[__Q__].Content" class="form-control question-content" rows="3" placeholder="Nhập câu hỏi..."></textarea>
            </div>
            <div class="col-lg-4">
                <label class="form-label">Loại câu hỏi</label>
                <select name="Questions[__Q__].QuestionType" class="form-select" data-question-type>
                    <option value="SingleChoice">Trắc nghiệm 1 đáp án</option>
                    <option value="MultipleChoice">Trắc nghiệm nhiều đáp án</option>
                </select>
                <div class="row g-2 mt-2">
                    <div class="col-6">
                        <label class="form-label">Điểm</label>
                        <input name="Questions[__Q__].Score" class="form-control" placeholder="Tự chia" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Độ khó</label>
                        <select name="Questions[__Q__].Difficulty" class="form-select">
                            <option value="Easy">Dễ</option>
                            <option value="Medium" selected>Trung bình</option>
                            <option value="Hard">Khó</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <label class="form-label">Ảnh câu hỏi</label>
                <input name="Questions[__Q__].ImageUrl" class="form-control" placeholder="Dán link ảnh nếu có" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Video câu hỏi</label>
                <input name="Questions[__Q__].VideoUrl" class="form-control" placeholder="Dán link video nếu có" />
            </div>
        </div>
        <div class="answer-builder-list" data-answer-list>
            __ANSWERS__
        </div>
        <div class="d-flex flex-wrap justify-content-between gap-2 mt-3">
            <button type="button" class="btn btn-outline-primary btn-sm" data-add-answer>+ Thêm đáp án</button>
            <textarea name="Questions[__Q__].Explanation" class="form-control question-explanation" rows="2" placeholder="Giải thích đáp án sau khi nộp bài nếu cần"></textarea>
        </div>
    </section>
</template>

<template id="answerTemplate">
    <div class="answer-builder-row" data-answer-row>
        <input type="hidden" name="Questions[__Q__].Options[__O__].IsCorrect" value="false" />
        <input class="form-check-input" type="checkbox" name="Questions[__Q__].Options[__O__].IsCorrect" value="true" __CHECKED__ title="Đáp án đúng" />
        <input name="Questions[__Q__].Options[__O__].Content" class="form-control" placeholder="Nhập đáp án" value="__VALUE__" />
        <button type="button" class="btn btn-light btn-sm" data-remove-answer>Xoá</button>
    </div>
</template>

@section Scripts {
    <script src="~/js/exam-builder.js" asp-append-version="true"></script>
}
