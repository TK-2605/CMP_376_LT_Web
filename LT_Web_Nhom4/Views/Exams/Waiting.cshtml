@model ExamRoomViewModel

@{ ViewData["Title"] = "Phòng chờ"; }
@section Styles { <link rel="stylesheet" href="~/css/exam.css" asp-append-version="true" /> }

<section class="waiting-page" data-waiting-room data-start-at="@Model.StartAt.ToString("O")" data-refresh-url="@Url.Action("Room", new { id = Model.Id })">
    <div class="container waiting-container">
        <a asp-controller="Classes" asp-action="Index" class="back-link"><i class="ri-arrow-left-line"></i> Lớp học của tôi</a>
        <div class="waiting-layout">
            <main class="waiting-main">
                @if (!string.IsNullOrWhiteSpace(Model.CoverImageUrl)) { <img src="@Model.CoverImageUrl" class="waiting-cover" alt="Ảnh lớp @Model.ClassName" /> }
                <div class="waiting-copy">
                    <div class="manage-labels"><span class="status-chip @(Model.IsClosed ? "closed" : "waiting")">@(Model.IsClosed ? "Đã kết thúc" : "Chưa mở")</span><code>@Model.Code</code></div>
                    <h1>@Model.Title</h1><p>@Model.ClassName · @Model.SubjectName</p>
                    <div class="room-facts"><div><span>Bắt đầu</span><strong>@Model.StartAt.ToString("dd/MM/yyyy HH:mm")</strong></div><div><span>Kết thúc</span><strong>@Model.EndAt.ToString("dd/MM/yyyy HH:mm")</strong></div><div><span>Thời lượng</span><strong>@Model.DurationMinutes phút</strong></div><div><span>Số câu</span><strong>@Model.QuestionCount câu</strong></div></div>
                </div>
            </main>
            <aside class="waiting-side">
                @if (Model.IsClosed)
                {
                    <i class="ri-time-line waiting-icon"></i><h2>Đề thi đã đóng</h2><p>Thời gian tham gia bài thi đã kết thúc.</p>
                }
                else
                {
                    <i class="ri-timer-line waiting-icon"></i><h2>Đang chờ đến giờ</h2><p>Trang sẽ tự chuyển khi đề thi được mở.</p><div class="countdown-display" data-wait-countdown>--:--:--</div>
                }
                <a asp-action="Room" asp-route-id="@Model.Id" class="btn btn-primary w-100">Kiểm tra lại</a>
            </aside>
        </div>
    </div>
</section>

@section Scripts { <script src="~/js/exam.js" asp-append-version="true"></script> }
