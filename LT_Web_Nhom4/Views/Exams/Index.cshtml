@model ExamListViewModel

@{ ViewData["Title"] = "Đề thi của tôi"; }

<section class="workspace-page">
    <div class="container">
        @if (TempData["ExamMessage"] is string message) { <div class="alert alert-success workspace-alert">@message</div> }
        <header class="workspace-header" data-reveal><div><span class="workspace-kicker">Đúng lớp, đúng quyền</span><h1>Đề thi của tôi</h1><p>Đề bạn tạo được tách riêng với đề bạn tham gia.</p></div><a asp-controller="Classes" asp-action="Index" class="btn btn-primary"><i class="ri-group-line"></i> Mở lớp học</a></header>

        <section class="workspace-section">
            <div class="workspace-section-heading"><h2>Đề tôi quản lý</h2><span>@Model.OwnedExams.Count đề</span></div>
            <div class="exam-card-grid">
                @if (Model.OwnedExams.Count == 0) { <div class="empty-state"><i class="ri-file-add-line"></i><strong>Chưa tạo đề thi</strong><span>Hãy mở một lớp học để tạo đề.</span></div> }
                @foreach (var exam in Model.OwnedExams)
                {
                    <article class="exam-tile" data-reveal><div class="exam-tile-heading"><span class="status-chip owner">Chủ phòng</span><code>@exam.Code</code></div><h3>@exam.Title</h3><p>@exam.ClassName &middot; @exam.SubjectName</p><dl><div><dt>Bắt đầu</dt><dd>@exam.StartAt.ToString("dd/MM/yyyy HH:mm")</dd></div><div><dt>Nội dung</dt><dd>@exam.QuestionCount câu &middot; @exam.DurationMinutes phút</dd></div></dl><a asp-action="Manage" asp-route-id="@exam.Id" class="btn btn-primary w-100">Quản lý đề thi</a></article>
                }
            </div>
        </section>

        <section class="workspace-section">
            <div class="workspace-section-heading"><h2>Đề tôi tham gia</h2><span>@Model.ParticipatingExams.Count đề</span></div>
            <div class="exam-card-grid">
                @if (Model.ParticipatingExams.Count == 0) { <div class="empty-state"><i class="ri-calendar-check-line"></i><strong>Chưa có đề thi</strong><span>Các đề được công bố trong lớp của bạn sẽ xuất hiện tại đây.</span></div> }
                @foreach (var exam in Model.ParticipatingExams)
                {
                    var now = Model.Now;
                    var state = exam.HasCompletedAttempt ? "completed" : now > exam.EndAt ? "closed" : now >= exam.StartAt ? "open" : "waiting";
                    var stateText = exam.HasCompletedAttempt ? "Đã hoàn thành" : now > exam.EndAt ? "Đã kết thúc" : now >= exam.StartAt ? "Đang mở" : "Phòng chờ";
                    <article class="exam-tile" data-reveal>
                        <div class="exam-tile-heading"><span class="status-chip @state">@stateText</span><code>@exam.Code</code></div>
                        <h3>@exam.Title</h3>
                        <p>@exam.ClassName &middot; @exam.SubjectName</p>
                        <dl>
                            <div><dt>Bắt đầu</dt><dd>@exam.StartAt.ToString("dd/MM/yyyy HH:mm")</dd></div>
                            <div><dt>Nội dung</dt><dd>@exam.QuestionCount câu &middot; @exam.DurationMinutes phút</dd></div>
                        </dl>
                        @if (exam.HasCompletedAttempt)
                        {
                            <a asp-action="Result" asp-route-attemptId="@exam.CurrentUserAttemptId" class="btn btn-outline-primary w-100">Xem kết quả</a>
                        }
                        else
                        {
                            <a asp-action="Room" asp-route-id="@exam.Id" class="btn btn-primary w-100">@(state == "open" ? "Vào làm bài" : "Mở phòng thi")</a>
                        }
                    </article>
                }
            </div>
        </section>
    </div>
</section>
