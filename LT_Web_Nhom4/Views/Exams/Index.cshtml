@model ExamListViewModel

@{
    ViewData["Title"] = Localizer["Exams"];
}

<section class="student-section bg-light">
    <div class="container">
        @if (TempData["ExamMessage"] is string message)
        {
            <div class="alert alert-success">@message</div>
        }

        <div class="row align-items-end mb-5">
            <div class="col-lg-7">
                <div class="student-eyebrow mb-2">@Localizer["Exams"]</div>
                <h1 class="display-6 fw-bold">@Localizer["ExamList"]</h1>
                <p class="text-muted mb-0">@Localizer["ExamListDesc"]</p>
            </div>
        </div>

        <div class="row g-4">
            @foreach (var exam in Model.Exams)
            {
                var now = DateTime.Now;
                var isOpen = now >= exam.StartAt && now <= exam.EndAt;
                var isClosed = now > exam.EndAt;
                <div class="col-lg-6">
                    <article class="card student-exam-card h-100">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                <span class="badge rounded-pill">@exam.SubjectName</span>
                                <span class="badge rounded-pill @(isOpen ? "text-bg-success" : isClosed ? "text-bg-secondary" : "text-bg-warning")">
                                    @(isOpen ? Localizer["Open"] : isClosed ? Localizer["Closed"] : Localizer["WaitingRoom"])
                                </span>
                            </div>
                            <h2 class="h4 fw-bold">@exam.Title</h2>
                            <p class="text-muted">@exam.ClassName - @Localizer["Questions", exam.QuestionCount]</p>
                            <div class="row g-3 mb-4">
                                <div class="col-sm-6">
                                    <div class="p-3 bg-light rounded-3">
                                        <small class="text-muted d-block">@Localizer["Start"]</small>
                                        <strong>@exam.StartAt.ToString("g")</strong>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="p-3 bg-light rounded-3">
                                        <small class="text-muted d-block">@Localizer["Duration"]</small>
                                        <strong>@Localizer["Minutes", exam.DurationMinutes]</strong>
                                    </div>
                                </div>
                            </div>
                            <a asp-controller="Exams" asp-action="Room" asp-route-id="@exam.Id" class="btn btn-primary">
                                @(isOpen ? Localizer["EnterExamRoom"] : Localizer["EnterWaitingRoom"])
                            </a>
                        </div>
                    </article>
                </div>
            }
        </div>
    </div>
</section>
