@model ExamRoomViewModel

@{ ViewData["Title"] = "Xác nhận làm bài"; }
@section Styles { <link rel="stylesheet" href="~/css/exam.css" asp-append-version="true" /> }

<section class="waiting-page">
    <div class="container waiting-container">
        <a asp-controller="Classes" asp-action="Index" class="back-link"><i class="ri-arrow-left-line"></i> Lớp học của tôi</a>
        <div class="waiting-layout confirm-layout" data-reveal>
            <main class="waiting-main">
                <img src="@(string.IsNullOrWhiteSpace(Model.CoverImageUrl) ? Url.Content("~/img/student/event-02.jpg") : Model.CoverImageUrl)" class="waiting-cover" alt="Ảnh lớp @Model.ClassName" />
                <div class="waiting-copy">
                    <div class="manage-labels"><span class="status-chip open">Đang mở</span><code>@Model.Code</code></div>
                    <h1>@Model.Title</h1><p>@Model.ClassName &middot; @Model.SubjectName</p>
                    <div class="room-facts"><div><span>Thời lượng</span><strong>@Model.DurationMinutes phút</strong></div><div><span>Số câu</span><strong>@Model.QuestionCount câu</strong></div><div><span>Điểm tối đa</span><strong>@Model.MaxScore.ToString("0.##")</strong></div><div><span>Cảnh báo tối đa</span><strong>@(Model.MaxWarningCount?.ToString() ?? "Không giới hạn")</strong></div></div>
                    <section class="exam-instructions"><h2>Hướng dẫn trước khi làm bài</h2><p>@(string.IsNullOrWhiteSpace(Model.Instructions) ? "Đọc kỹ từng câu hỏi, kiểm tra đáp án và thời gian còn lại trước khi nộp bài." : Model.Instructions)</p><ul><li>Mỗi học viên chỉ có một lượt làm bài.</li><li>Đáp án được tự động lưu sau mỗi thay đổi.</li><li>Đạt giới hạn cảnh báo sẽ tự động nộp bài.</li></ul></section>
                </div>
            </main>
            <aside class="waiting-side">
                <i class="ri-shield-check-line waiting-icon success"></i><h2>Sẵn sàng bắt đầu?</h2><p>Đồng hồ sẽ tính ngay sau khi bạn xác nhận.</p>
                <form asp-action="Start" asp-route-id="@Model.Id" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <label class="confirm-check"><input type="checkbox" name="acceptRules" value="true" /><span>Tôi đã đọc hướng dẫn và sẵn sàng làm bài.</span></label>
                    <button type="submit" class="btn btn-primary w-100 mt-3" data-confirm="Bắt đầu lượt thi ngay bây giờ? Đồng hồ sẽ bắt đầu tính sau khi xác nhận.">Bắt đầu làm bài</button>
                </form>
            </aside>
        </div>
    </div>
</section>
