@model CrudDetailsViewModel

@{
    ViewData["Title"] = $"Chi tiết {Model.Title}";
}

@{
    var visibleFields = Model.Fields.Where(field => field.ShowInDetails).ToList();
}

<section class="crud-page">
    <div class="container">
        <div class="card crud-form-card">
            <div class="card-body">
                <span class="crud-kicker">Chi tiết</span>
                <h1>@Model.Title</h1>

                <dl class="crud-detail-list">
                    @foreach (var field in visibleFields)
                    {
                        <div>
                            <dt>@field.Label</dt>
                            <dd>@(field.IsBoolean ? (field.Value == "true" ? "Co" : "Khong") : field.Value ?? "-")</dd>
                        </div>
                    }
                </dl>

                <div class="crud-form-actions">
                    <a asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="Index" class="btn btn-light">Quay lại</a>
                    <a asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="Edit" asp-route-id="@Model.Key" class="btn btn-primary">Sửa</a>
                </div>
            </div>
        </div>
    </div>
</section>
