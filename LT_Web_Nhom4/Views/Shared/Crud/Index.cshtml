@model CrudIndexViewModel

@{
    ViewData["Title"] = Model.Title;
}

@{
    var visibleFields = Model.Fields.Where(field => field.ShowInList).ToList();
}

<section class="crud-page">
    <div class="container">
        <div class="crud-header">
            <div>
                <span class="crud-kicker">Quan ly</span>
                <h1>@Model.Title</h1>
                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <p>@Model.Description</p>
                }
            </div>
            <a asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="Create" class="btn btn-primary">Them moi</a>
        </div>

        <div class="card crud-card">
            <div class="table-responsive">
                <table class="table crud-table align-middle mb-0">
                    <thead>
                        <tr>
                            @foreach (var field in visibleFields)
                            {
                                <th>@field.Label</th>
                            }
                            <th class="text-end">Thao tac</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Rows.Count == 0)
                        {
                            <tr>
                                <td colspan="@(visibleFields.Count + 1)">
                                    <div class="crud-empty">
                                        <strong>Chua co du lieu</strong>
                                        <span>Hay them ban ghi dau tien de bat dau quan ly.</span>
                                    </div>
                                </td>
                            </tr>
                        }
                        @foreach (var row in Model.Rows)
                        {
                            <tr>
                                @foreach (var field in visibleFields)
                                {
                                    <td>
                                        <span class="crud-cell-value">@(row.Values.TryGetValue(field.Name, out var value) ? value : "-")</span>
                                    </td>
                                }
                                <td class="text-end text-nowrap">
                                    <a asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="Details" asp-route-id="@row.Key" class="btn btn-sm btn-light">Xem</a>
                                    <a asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="Edit" asp-route-id="@row.Key" class="btn btn-sm btn-outline-primary">Sua</a>
                                    <a asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="Delete" asp-route-id="@row.Key" class="btn btn-sm btn-outline-danger">Xoa</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
