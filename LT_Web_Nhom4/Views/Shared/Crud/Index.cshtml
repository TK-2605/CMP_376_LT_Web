@model CrudIndexViewModel

@{
    ViewData["Title"] = Model.Title;
}

<section class="student-section bg-light">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
            <div>
                <div class="student-eyebrow mb-2">CRUD</div>
                <h1 class="h3 fw-bold mb-0">@Model.Title</h1>
            </div>
            <a asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="Create" class="btn btn-primary">Create</a>
        </div>

        <div class="card">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            @foreach (var field in Model.Fields.Take(6))
                            {
                                <th>@field.Label</th>
                            }
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Rows.Count == 0)
                        {
                            <tr>
                                <td colspan="@(Model.Fields.Take(6).Count() + 1)" class="text-center text-muted py-4">No data</td>
                            </tr>
                        }
                        @foreach (var row in Model.Rows)
                        {
                            <tr>
                                @foreach (var field in Model.Fields.Take(6))
                                {
                                    <td>@(row.Values.TryGetValue(field.Name, out var value) ? value : null)</td>
                                }
                                <td class="text-end text-nowrap">
                                    <a asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="Details" asp-route-id="@row.Key" class="btn btn-sm btn-outline-secondary">Details</a>
                                    <a asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="Edit" asp-route-id="@row.Key" class="btn btn-sm btn-outline-primary">Edit</a>
                                    <a asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="Delete" asp-route-id="@row.Key" class="btn btn-sm btn-outline-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
