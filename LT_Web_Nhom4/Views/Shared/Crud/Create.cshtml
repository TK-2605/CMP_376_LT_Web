@model CrudFormViewModel

@{
    ViewData["Title"] = Model.Title;
}

<section class="crud-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-8 col-lg-9">
                <div class="card crud-form-card">
                    <div class="card-body">
                        <span class="crud-kicker">Bieu mau</span>
                        <h1>@Model.Title</h1>
                        @if (!string.IsNullOrWhiteSpace(Model.Description))
                        {
                            <p class="crud-form-description">@Model.Description</p>
                        }
                        <partial name="/Views/Shared/Crud/_Form.cshtml" model="Model" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
