@model CrudDeleteViewModel

@{
    ViewData["Title"] = $"Xoa {Model.Title}";
}

@{
    var visibleFields = Model.Fields.Where(field => field.ShowInDetails).Take(6).ToList();
}

<section class="crud-page">
    <div class="container">
        <div class="card crud-form-card border-danger">
            <div class="card-body">
                <span class="crud-kicker text-danger">Xac nhan xoa</span>
                <h1>Xoa @Model.Title</h1>
                <p class="crud-form-description text-danger">Ban ghi se bi xoa khoi he thong sau khi xac nhan.</p>

                <dl class="crud-detail-list">
                    @foreach (var field in visibleFields)
                    {
                        <div>
                            <dt>@field.Label</dt>
                            <dd>@(field.IsBoolean ? (field.Value == "true" ? "Co" : "Khong") : field.Value ?? "-")</dd>
                        </div>
                    }
                </dl>

                <form asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="Delete" asp-route-id="@Model.Key" method="post">
                    <div class="crud-form-actions">
                        <a asp-area="@Model.AreaName" asp-controller="@Model.ControllerName" asp-action="Index" class="btn btn-light">Huy</a>
                        <button type="submit" class="btn btn-danger">Xoa</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
