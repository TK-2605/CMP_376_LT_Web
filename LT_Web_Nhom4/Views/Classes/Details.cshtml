@model ClassDetailsViewModel

@{
    ViewData["Title"] = Model.Name;
}

<section class="workspace-page">
    <div class="container">
        @if (TempData["ClassMessage"] is string message)
        {
            <div class="alert alert-success workspace-alert">@message</div>
        }

        <header class="class-detail-hero" data-reveal>
            <div class="class-detail-cover">
                @if (!string.IsNullOrWhiteSpace(Model.CoverImageUrl))
                {
                    <img src="@Model.CoverImageUrl" alt="Ảnh bìa lớp @Model.Name" />
                }
                else
                {
                    <img src="~/img/student/course-01.jpg" alt="Ảnh minh họa lớp @Model.Name" />
                }
            </div>

            <div class="class-detail-copy">
                <div class="class-detail-labels">
                    <span class="status-chip @(Model.IsOwner ? "owner" : "member")">@(Model.IsOwner ? "Chủ lớp" : "Thành viên")</span>
                    <span class="class-code-pill"><span>QuizHub</span><strong>@Model.Code</strong></span>
                </div>
                <h1>@Model.Name</h1>
                <p>@(string.IsNullOrWhiteSpace(Model.Description) ? Model.SubjectName : Model.Description)</p>
                <div class="class-detail-meta">
                    <span><i class="ri-book-open-line"></i> @Model.SubjectName</span>
                    <span><i class="ri-group-line"></i> @Model.MemberCount học viên</span>
                    <span><i class="ri-file-list-3-line"></i> @Model.ExamCount đề thi</span>
                </div>
            </div>

            <div class="class-detail-actions">
                <a asp-action="Index" class="btn btn-light"><i class="ri-arrow-left-line"></i> Danh sách</a>
                <a asp-controller="Chat" asp-action="Room" asp-route-type="class" asp-route-id="@Model.Id" class="btn btn-outline-primary"><i class="ri-chat-3-line"></i> Chat lớp</a>
                @if (Model.IsOwner)
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary"><i class="ri-edit-line"></i> Chỉnh sửa lớp</a>
                    <a asp-controller="Exams" asp-action="CreateInClass" asp-route-classId="@Model.Id" class="btn btn-primary"><i class="ri-add-line"></i> Tạo đề thi</a>
                }
            </div>
        </header>

        <div class="class-detail-grid" data-reveal>
            <main>
                @if (Model.MediaAssets.Count > 0)
                {
                    <section class="surface-section">
                        <div class="surface-heading">
                            <div><span class="workspace-kicker">Tư liệu lớp</span><h2>Ảnh và video</h2></div>
                        </div>
                        <div class="class-media-gallery">
                            @foreach (var media in Model.MediaAssets)
                            {
                                if (media.IsImage)
                                {
                                    <img src="@media.Url" alt="Ảnh lớp học @Model.Name" />
                                }
                                else
                                {
                                    <video controls preload="metadata">
                                        <source src="@media.Url" />
                                    </video>
                                }
                            }
                        </div>
                    </section>
                }

                <section class="surface-section">
                    <div class="surface-heading">
                        <div><span class="workspace-kicker">Nội dung lớp</span><h2>Đề thi</h2></div>
                    </div>
                    @if (Model.Exams.Count == 0)
                    {
                        <div class="empty-state compact">
                            <i class="ri-file-list-3-line"></i>
                            <strong>Chưa có đề thi</strong>
                            <span>@(Model.IsOwner ? "Tạo đề đầu tiên cho lớp học này." : "Người tạo lớp chưa công bố đề thi.")</span>
                        </div>
                    }
                    else
                    {
                        <div class="exam-row-list">
                            @foreach (var exam in Model.Exams)
                            {
                                var now = DateTime.Now;
                                var state = exam.HasCompletedAttempt ? "completed" : exam.Status == ExamStatus.Draft ? "draft" : now > exam.EndAt ? "closed" : now >= exam.StartAt ? "open" : "waiting";
                                var stateText = exam.HasCompletedAttempt ? "Đã hoàn thành" : exam.Status == ExamStatus.Draft ? "Bản nháp" : now > exam.EndAt ? "Đã kết thúc" : now >= exam.StartAt ? "Đang mở" : "Chưa mở";
                                var actionName = Model.IsOwner ? "Manage" : exam.HasCompletedAttempt ? "Result" : "Room";
                                var buttonText = Model.IsOwner ? "Quản lý" : exam.HasCompletedAttempt ? "Xem kết quả" : "Vào phòng";
                                <article class="exam-row">
                                    <div class="exam-row-date"><strong>@exam.StartAt.ToString("dd")</strong><span>@exam.StartAt.ToString("MM/yyyy")</span></div>
                                    <div class="exam-row-content">
                                        <div><span class="status-chip @state">@stateText</span><code>@exam.Code</code></div>
                                        <h3>@exam.Title</h3>
                                        <p>@exam.QuestionCount câu · @exam.DurationMinutes phút · @exam.StartAt.ToString("HH:mm")</p>
                                    </div>
                                    @if (exam.HasCompletedAttempt && !Model.IsOwner)
                                    {
                                        <a asp-controller="Exams" asp-action="@actionName" asp-route-attemptId="@exam.CurrentUserAttemptId" class="btn btn-outline-primary">@buttonText</a>
                                    }
                                    else
                                    {
                                        <a asp-controller="Exams" asp-action="@actionName" asp-route-id="@exam.Id" class="btn @(Model.IsOwner ? "btn-outline-primary" : "btn-primary")">@buttonText</a>
                                    }
                                </article>
                            }
                        </div>
                    }
                </section>
            </main>

            <aside>
                <section class="surface-section class-code-card">
                    <span class="workspace-kicker">Mã tham gia</span>
                    <h2>QuizHub : @Model.Code</h2>
                    <p>Chỉ người có mã lớp mới tham gia được lớp học này.</p>
                    @if (Model.IsOwner)
                    {
                        <form asp-action="RegenerateCode" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-light w-100" data-confirm="Mã cũ sẽ hết hiệu lực. Tạo mã lớp mới?"><i class="ri-refresh-line"></i> Đổi mã lớp</button>
                        </form>
                    }
                </section>

                <section class="surface-section">
                    <div class="surface-heading"><div><span class="workspace-kicker">Thành viên</span><h2>@Model.MemberCount học viên</h2></div></div>
                    @if (!Model.IsOwner)
                    {
                        <p class="muted-copy">Danh sách thành viên chỉ hiển thị với chủ lớp.</p>
                    }
                    else if (Model.Members.Count == 0)
                    {
                        <div class="empty-state compact">
                            <i class="ri-user-add-line"></i>
                            <strong>Chưa có học viên</strong>
                            <span>Chia sẻ mã <b>QuizHub : @Model.Code</b> để mời tham gia.</span>
                        </div>
                    }
                    else
                    {
                        <div class="member-list">
                            @foreach (var member in Model.Members)
                            {
                                var initial = string.IsNullOrWhiteSpace(member.DisplayName) ? "?" : member.DisplayName.Trim()[0].ToString().ToUpperInvariant();
                                <div class="member-row">
                                    <span class="member-avatar">@initial</span>
                                    <span><strong>@member.DisplayName</strong><small>@member.Email</small></span>
                                    <form asp-action="RemoveMember" method="post">
                                        <input type="hidden" name="id" value="@Model.Id" />
                                        <input type="hidden" name="userId" value="@member.UserId" />
                                        <button type="submit" class="icon-button danger" title="Xóa khỏi lớp" data-confirm="Xóa học viên này khỏi lớp?"><i class="ri-user-unfollow-line"></i></button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                </section>
            </aside>
        </div>
    </div>
</section>
