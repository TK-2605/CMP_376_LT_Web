@model EditClassViewModel

@{
    ViewData["Title"] = "Chỉnh sửa lớp học";
}

<section class="workspace-page">
    <div class="container form-page-container">
        <a asp-action="Details" asp-route-id="@Model.Id" class="back-link"><i class="ri-arrow-left-line"></i> Quay lại lớp</a>

        <header class="form-page-heading">
            <span class="workspace-kicker">Mã lớp @Model.Code</span>
            <h1>Chỉnh sửa lớp học</h1>
            <p>Cập nhật nội dung hiển thị với các thành viên trong lớp.</p>
        </header>

        <form asp-action="Edit" method="post" enctype="multipart/form-data" class="content-form" data-reveal>
            <input asp-for="Id" type="hidden" />
            <input asp-for="RowVersion" type="hidden" />
            <input asp-for="IntroVideoUrl" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="form-grid">
                <div class="form-field span-2">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control form-control-lg" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-field span-2">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-field">
                    <label asp-for="SubjectId" class="form-label"></label>
                    <select asp-for="SubjectId" class="form-select" data-existing-subject>
                        @foreach (var subject in Model.Subjects)
                        {
                            <option value="@subject.Id">@subject.Label</option>
                        }
                    </select>
                    <span asp-validation-for="SubjectId" class="text-danger"></span>
                </div>

                <div class="form-field span-2 subject-inline-panel">
                    <label class="switch-row subject-create-toggle">
                        <span><strong>Tạo môn học riêng mới</strong><small>Dùng khi lớp này cần môn khác với danh sách hiện tại. Mã và tên sẽ được kiểm tra trùng trước khi lưu.</small></span>
                        <input asp-for="CreateNewSubject" class="form-check-input" type="checkbox" role="switch" data-new-subject-toggle />
                    </label>
                    <div class="subject-inline-fields" data-new-subject-fields>
                        <div>
                            <label asp-for="NewSubjectCode" class="form-label"></label>
                            <input asp-for="NewSubjectCode" class="form-control" placeholder="Ví dụ: WEB-N4" data-subject-code-input />
                            <span asp-validation-for="NewSubjectCode" class="text-danger"></span>
                        </div>
                        <div>
                            <label asp-for="NewSubjectName" class="form-label"></label>
                            <input asp-for="NewSubjectName" class="form-control" placeholder="Ví dụ: Lập trình Web" />
                            <span asp-validation-for="NewSubjectName" class="text-danger"></span>
                        </div>
                        <div class="span-2">
                            <label asp-for="NewSubjectDescription" class="form-label"></label>
                            <textarea asp-for="NewSubjectDescription" class="form-control" rows="2" placeholder="Ghi chú ngắn nếu cần"></textarea>
                            <span asp-validation-for="NewSubjectDescription" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-field">
                    <label asp-for="Semester" class="form-label"></label>
                    <input asp-for="Semester" class="form-control" />
                </div>

                <div class="form-field">
                    <label asp-for="AcademicYear" class="form-label"></label>
                    <input asp-for="AcademicYear" class="form-control" />
                </div>

                @if (Model.ExistingMedia.Count > 0 || !string.IsNullOrWhiteSpace(Model.ExistingCoverImageUrl))
                {
                    <div class="form-field span-2">
                        <label class="form-label">Media hiện có</label>
                        <div class="media-manage-grid">
                            @foreach (var media in Model.ExistingMedia)
                            {
                                <label class="media-manage-item">
                                    @if (media.IsImage)
                                    {
                                        <img src="@media.Url" alt="Ảnh lớp học" />
                                    }
                                    else
                                    {
                                        <span class="media-video-thumb"><i class="ri-video-line"></i> Video</span>
                                    }
                                    <span>
                                        <input type="checkbox" name="RemoveMediaIds" value="@media.Id" />
                                        Xóa file này
                                    </span>
                                </label>
                            }

                            @if (Model.ExistingMedia.Count == 0 && !string.IsNullOrWhiteSpace(Model.ExistingCoverImageUrl))
                            {
                                <label class="media-manage-item">
                                    <img src="@Model.ExistingCoverImageUrl" alt="Ảnh bìa hiện tại" />
                                    <span><input asp-for="RemoveCoverImage" /> Xóa ảnh bìa cũ</span>
                                </label>
                            }
                        </div>
                    </div>
                }

                <div class="form-field span-2">
                    <label asp-for="ImageFiles" class="form-label">Thêm ảnh lớp học</label>
                    <label class="upload-field">
                        <i class="ri-image-add-line" aria-hidden="true"></i>
                        <span>
                            <strong>Chọn thêm ảnh</strong>
                            <small>Tổng tối đa 5 ảnh. JPG, PNG hoặc WebP, mỗi ảnh tối đa 5 MB.</small>
                        </span>
                        <input asp-for="ImageFiles" type="file" accept="image/jpeg,image/png,image/webp" multiple data-media-preview="#classImagePreview" data-media-preview-type="image" />
                    </label>
                    <div id="classImagePreview" class="selected-media-preview" hidden></div>
                    <span asp-validation-for="ImageFiles" class="text-danger"></span>
                </div>

                <div class="form-field span-2">
                    <label asp-for="VideoFiles" class="form-label">Thêm video lớp học</label>
                    <label class="upload-field">
                        <i class="ri-video-add-line" aria-hidden="true"></i>
                        <span>
                            <strong>Chọn thêm video</strong>
                            <small>Tổng tối đa 2 video. MP4, WebM hoặc MOV, mỗi video tối đa 100 MB.</small>
                        </span>
                        <input asp-for="VideoFiles" type="file" accept="video/mp4,video/webm,video/quicktime" multiple data-media-preview="#classVideoPreview" data-media-preview-type="video" />
                    </label>
                    <div id="classVideoPreview" class="selected-media-preview" hidden></div>
                    <span asp-validation-for="VideoFiles" class="text-danger"></span>
                </div>
            </div>

            <div class="form-actions">
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-light">Hủy</a>
                <button class="btn btn-primary" type="submit">Lưu thay đổi</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
