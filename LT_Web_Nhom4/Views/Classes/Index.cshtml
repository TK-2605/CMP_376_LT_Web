@model ClassListViewModel

@{
    ViewData["Title"] = "Lớp học của tôi";
}

<section class="workspace-page">
    <div class="container">
        @if (TempData["ClassMessage"] is string message)
        {
            <div class="alert alert-success workspace-alert">@message</div>
        }

        <header class="workspace-header" data-reveal>
            <div>
                <span class="workspace-kicker">Không gian học tập riêng tư</span>
                <h1>Lớp học của tôi</h1>
                <p>Chỉ lớp bạn tạo hoặc đã tham gia mới xuất hiện tại đây.</p>
            </div>
            <a asp-action="Create" class="btn btn-primary"><i class="ri-add-line" aria-hidden="true"></i> Tạo lớp</a>
        </header>

        @if (Model.OwnedClasses.Count == 0 && Model.ParticipatingClasses.Count == 0)
        {
            <div class="alert alert-info workspace-alert class-empty-alert" role="status">
                <i class="ri-information-line" aria-hidden="true"></i>
                <span>Bạn chưa có lớp học nào. Hãy nhập mã lớp để tham gia, hoặc bấm <strong>Tạo lớp</strong> nếu bạn là chủ lớp.</span>
            </div>
        }

        <div class="workspace-tools" data-reveal>
            <form asp-action="Join" method="post" class="join-code-form">
                <div>
                    <label asp-for="JoinClass.Code" class="form-label">Tham gia bằng mã lớp</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="ri-key-2-line" aria-hidden="true"></i></span>
                        <input asp-for="JoinClass.Code" name="Code" class="form-control" placeholder="ABC-DEF-GHJ" autocomplete="off" data-class-code />
                        <button type="submit" class="btn btn-primary">Tham gia</button>
                    </div>
                    <span asp-validation-for="JoinClass.Code" class="text-danger"></span>
                </div>
            </form>
            <label class="class-filter">
                <span>Tìm trong lớp của tôi</span>
                <span class="input-with-icon"><i class="ri-search-line" aria-hidden="true"></i><input class="form-control" type="search" placeholder="Tên lớp hoặc môn học" data-class-filter /></span>
            </label>
        </div>

        <section class="workspace-section">
            <div class="workspace-section-heading"><h2>Lớp tôi tạo</h2><span>@Model.OwnedClasses.Count lớp</span></div>
            <div class="class-grid" data-class-grid>
                @if (Model.OwnedClasses.Count == 0)
                {
                    <div class="empty-state"><i class="ri-layout-grid-line"></i><strong>Chưa có lớp nào</strong><span>Tạo lớp đầu tiên để bắt đầu soạn đề.</span></div>
                }
                @foreach (var classRoom in Model.OwnedClasses)
                {
                    <article class="class-tile" data-class-card data-reveal data-search-text="@($"{classRoom.Name} {classRoom.SubjectName} {classRoom.Code}".ToLowerInvariant())">
                        <div class="class-tile-cover">
                            @if (!string.IsNullOrWhiteSpace(classRoom.CoverImageUrl)) { <img src="@classRoom.CoverImageUrl" alt="Ảnh bìa lớp @classRoom.Name" /> }
                            else { <img src="~/img/student/course-02.jpg" alt="Ảnh minh hoạ lớp @classRoom.Name" /> }
                        </div>
                        <div class="class-tile-body">
                            <div class="class-tile-topline"><span class="status-chip owner">Chủ lớp</span><code>@classRoom.Code</code></div>
                            <h3>@classRoom.Name</h3><p>@classRoom.SubjectName</p>
                            <div class="class-tile-meta"><span>@classRoom.ExamCount đề thi</span><span>@classRoom.MemberCount học viên</span></div>
                            <a asp-action="Details" asp-route-id="@classRoom.Id" class="btn btn-primary w-100">Mở lớp</a>
                        </div>
                    </article>
                }
            </div>
        </section>

        <section class="workspace-section">
            <div class="workspace-section-heading"><h2>Lớp tôi tham gia</h2><span>@Model.ParticipatingClasses.Count lớp</span></div>
            <div class="class-grid" data-class-grid>
                @if (Model.ParticipatingClasses.Count == 0)
                {
                    <div class="empty-state"><i class="ri-key-2-line"></i><strong>Chưa tham gia lớp</strong><span>Nhập mã lớp do người tạo cung cấp.</span></div>
                }
                @foreach (var classRoom in Model.ParticipatingClasses)
                {
                    <article class="class-tile" data-class-card data-reveal data-search-text="@($"{classRoom.Name} {classRoom.SubjectName} {classRoom.Code}".ToLowerInvariant())">
                        <div class="class-tile-cover">
                            @if (!string.IsNullOrWhiteSpace(classRoom.CoverImageUrl)) { <img src="@classRoom.CoverImageUrl" alt="Ảnh bìa lớp @classRoom.Name" /> }
                            else { <img src="~/img/student/course-03.jpg" alt="Ảnh minh hoạ lớp @classRoom.Name" /> }
                        </div>
                        <div class="class-tile-body">
                            <div class="class-tile-topline"><span class="status-chip member">Thành viên</span><code>@classRoom.Code</code></div>
                            <h3>@classRoom.Name</h3><p>@classRoom.SubjectName</p>
                            <div class="class-tile-meta"><span>@classRoom.ExamCount đề thi</span><span>@classRoom.MemberCount học viên</span></div>
                            <a asp-action="Details" asp-route-id="@classRoom.Id" class="btn btn-outline-primary w-100">Vào lớp</a>
                        </div>
                    </article>
                }
            </div>
        </section>
    </div>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
