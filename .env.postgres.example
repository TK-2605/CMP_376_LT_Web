# Copy this file to .env.postgres and replace every CHANGE_ME value.
# Do not commit .env.postgres.

POSTGRES_CONNECTION_STRING=Host=CHANGE_ME.neon.tech;Database=neondb;Username=CHANGE_ME;Password=CHANGE_ME;SSL Mode=Require;Trust Server Certificate=true

DATABASE_PROVIDER=PostgreSql
DATABASE_ENSURE_CREATED_ON_STARTUP=true
DATABASE_APPLY_MIGRATIONS_ON_STARTUP=false

GOOGLE_CLIENT_ID=CHANGE_ME_google_client_id
GOOGLE_CLIENT_SECRET=CHANGE_ME_google_client_secret

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE_SOCKET_OPTIONS=StartTls
SMTP_TIMEOUT_SECONDS=20
SMTP_USERNAME=CHANGE_ME_gmail_address
SMTP_PASSWORD=CHANGE_ME_gmail_app_password
SMTP_FROM_EMAIL=CHANGE_ME_gmail_address
SMTP_FROM_NAME=QuizHub

JWT_ISSUER=QuizHub
JWT_AUDIENCE=QuizHub.Api
JWT_KEY=CHANGE_ME_generate_at_least_64_random_characters
JWT_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_DAYS=7

MEILI_URL=
MEILI_API_KEY=
MEILI_INDEX_NAME=quizhub-private-search

PRIVATE_MEDIA_ROOT=/tmp/quizhub-uploads
SWAGGER_ENABLED=true

# Optional live smoke test credentials. These are not app settings.
ADMIN_TEST_EMAIL=
ADMIN_TEST_PASSWORD=
